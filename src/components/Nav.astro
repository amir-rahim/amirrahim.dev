---
import { SITE } from '../config/site';

const currentPath = Astro.url.pathname;
---

<header class="site-nav">
	<nav class="container nav-inner" aria-label="Main navigation">
		<a href="/" class="nav-logo" aria-label={`${SITE.title} — home`}>
			<span class="logo-name">AR</span>
		</a>

		<ul class="nav-links" role="list">
			{
				SITE.nav
					.filter((item) => item.href !== '/')
					.map((item) => {
						const isActive = currentPath.startsWith(item.href);
						return (
							<li>
								<a
									href={item.href}
									class:list={['nav-link', { active: isActive }]}
									aria-current={isActive ? 'page' : undefined}
								>
									{item.label}
								</a>
							</li>
						);
					})
			}
		</ul>

		<div class="nav-actions">
			<button
				class="theme-toggle"
				id="theme-toggle"
				aria-label="Toggle light/dark mode"
				type="button"
			>
				<svg class="icon-sun" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
					<circle cx="12" cy="12" r="4"/><path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M6.34 17.66l-1.41 1.41M19.07 4.93l-1.41 1.41"/>
				</svg>
				<svg class="icon-moon" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
					<path d="M12 3a6 6 0 0 0 9 9 9 9 0 1 1-9-9Z"/>
				</svg>
			</button>

			<a
				href={SITE.social.github}
				class="nav-social"
				target="_blank"
				rel="noopener noreferrer"
				aria-label="GitHub profile"
			>
				<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
					<path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23A11.509 11.509 0 0 1 12 5.803c1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576C20.566 21.797 24 17.3 24 12c0-6.627-5.373-12-12-12z"/>
				</svg>
			</a>
		</div>
	</nav>
</header>

<style>
	.site-nav {
		position: sticky;
		top: 0;
		z-index: 100;
		background: hsla(222 20% 7% / 0.85);
		backdrop-filter: blur(12px) saturate(1.2);
		-webkit-backdrop-filter: blur(12px) saturate(1.2);
		border-bottom: 1px solid var(--color-border);
		transition: background var(--dur-base) ease, border-color var(--dur-base) ease;
	}

	[data-theme='light'] .site-nav,
	@media (prefers-color-scheme: light) {
		.site-nav {
			background: hsla(222 20% 97% / 0.88);
		}
	}

	.nav-inner {
		display: flex;
		align-items: center;
		gap: var(--space-xl);
		height: 3.5rem;
	}

	.nav-logo {
		flex-shrink: 0;
		text-decoration: none;
	}

	.logo-name {
		font-family: var(--font-mono);
		font-size: 0.875rem;
		font-weight: 500;
		letter-spacing: 0.08em;
		color: var(--color-accent);
		border: 1px solid var(--color-accent-dim);
		padding: 0.3em 0.6em;
		border-radius: 4px;
		transition: box-shadow var(--dur-fast) ease;
	}

	.logo-name:hover {
		box-shadow: var(--shadow-accent-glow);
	}

	.nav-links {
		display: flex;
		align-items: center;
		gap: var(--space-sm);
		list-style: none;
		flex: 1;
	}

	.nav-link {
		font-size: 0.875rem;
		font-weight: 500;
		color: var(--color-text-muted);
		padding: 0.4em 0.75em;
		border-radius: var(--radius-sm);
		transition: color var(--dur-fast) ease, background var(--dur-fast) ease;
	}

	.nav-link:hover {
		color: var(--color-text);
		background: var(--color-surface);
	}

	.nav-link.active {
		color: var(--color-text);
	}

	.nav-actions {
		display: flex;
		align-items: center;
		gap: var(--space-sm);
		margin-left: auto;
	}

	.theme-toggle {
		display: flex;
		align-items: center;
		justify-content: center;
		width: 2rem;
		height: 2rem;
		border-radius: var(--radius-sm);
		border: 1px solid var(--color-border);
		background: transparent;
		color: var(--color-text-muted);
		cursor: pointer;
		transition:
			color var(--dur-fast) ease,
			background var(--dur-fast) ease,
			border-color var(--dur-fast) ease;
	}

	.theme-toggle:hover {
		color: var(--color-text);
		background: var(--color-surface);
	}

	/* Show/hide sun/moon icons based on current theme */
	.icon-sun { display: none; }
	.icon-moon { display: block; }

	[data-theme='light'] .icon-sun,
	:root[style*='color-scheme: light'] .icon-sun { display: block; }
	[data-theme='light'] .icon-moon,
	:root[style*='color-scheme: light'] .icon-moon { display: none; }

	.nav-social {
		display: flex;
		align-items: center;
		justify-content: center;
		width: 2rem;
		height: 2rem;
		border-radius: var(--radius-sm);
		border: 1px solid var(--color-border);
		color: var(--color-text-muted);
		transition:
			color var(--dur-fast) ease,
			background var(--dur-fast) ease,
			border-color var(--dur-fast) ease;
	}

	.nav-social:hover {
		color: var(--color-text);
		background: var(--color-surface);
	}

	@media (max-width: 640px) {
		.nav-links {
			display: none;
		}
	}
</style>

<script>
	function initThemeToggle() {
		const btn = document.getElementById('theme-toggle');
		if (!btn) return;

		function updateIcons() {
			const theme = document.documentElement.dataset.theme ?? 'dark';
			const sun = btn!.querySelector('.icon-sun') as HTMLElement | null;
			const moon = btn!.querySelector('.icon-moon') as HTMLElement | null;
			if (sun) sun.style.display = theme === 'light' ? 'block' : 'none';
			if (moon) moon.style.display = theme === 'light' ? 'none' : 'block';
		}

		btn.addEventListener('click', () => {
			const current = document.documentElement.dataset.theme ?? 'dark';
			const next = current === 'dark' ? 'light' : 'dark';
			document.documentElement.dataset.theme = next;
			localStorage.setItem('theme', next);
			updateIcons();
		});

		updateIcons();
	}

	initThemeToggle();
	document.addEventListener('astro:page-load', initThemeToggle);
</script>
