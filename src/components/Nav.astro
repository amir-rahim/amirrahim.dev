---
import { SITE } from '../config/site';

const currentPath = Astro.url.pathname;

const navItems = [
	{ label: 'Resume',   href: '/resume',   num: '001' },
	{ label: 'Projects', href: '/projects', num: '002' },
	{ label: 'Blog',     href: '/blog',     num: '003' },
] as const;
---

<header class="site-header">
	<nav class="page-wrap nav-inner" aria-label="Main navigation">
		<a href="/" class="nav-logo" aria-label={`${SITE.title} — home`}>AR.</a>

		<ul class="nav-links" role="list">
			{navItems.map(({ label, href, num }) => {
				const isActive = currentPath.startsWith(href);
				return (
					<li>
						<a
							href={href}
							class:list={['nav-link', { active: isActive }]}
							aria-current={isActive ? 'page' : undefined}
						>
							<span class="nav-num">{num}</span>
							<span class="nav-sep">—</span>
							{label}
						</a>
					</li>
				);
			})}
		</ul>

		<div class="nav-end">
			<button
				class="theme-btn"
				id="theme-toggle"
				type="button"
				aria-label="Toggle colour mode"
			>
				<span id="theme-label" class="label"></span>
			</button>
		</div>
	</nav>
</header>

<style>
	.site-header {
		position: sticky;
		top: 0;
		z-index: 100;
		background: var(--color-bg);
		border-top: 1.5px solid var(--color-rule-heavy);
		border-bottom: 1.5px solid var(--color-rule-heavy);
	}

	.nav-inner {
		display: flex;
		align-items: center;
		height: 2.875rem;
		gap: var(--space-xl);
	}

	/* "AR." — bold monospace logo */
	.nav-logo {
		font-family: var(--font-mono);
		font-size: 0.8125rem;
		font-weight: 700;
		letter-spacing: -0.01em;
		color: var(--color-text);
		flex-shrink: 0;
	}

	.nav-links {
		display: flex;
		list-style: none;
		flex: 1;
		height: 100%;
	}

	.nav-link {
		display: flex;
		align-items: center;
		gap: 0.45em;
		height: 100%;
		padding-inline: var(--space-md);
		font-family: var(--font-mono);
		font-size: var(--text-label);
		letter-spacing: 0.07em;
		text-transform: uppercase;
		color: var(--color-text-muted);
		position: relative;
		text-decoration: none;
		transition: color var(--dur-fast) ease;
	}

	/* underline slides in from left */
	.nav-link::after {
		content: '';
		position: absolute;
		bottom: -1px; /* sits on the bottom border */
		left: var(--space-md);
		right: var(--space-md);
		height: 1.5px;
		background: var(--color-text);
		transform: scaleX(0);
		transform-origin: left;
		transition: transform var(--dur-base) ease;
	}

	.nav-link:hover,
	.nav-link.active { color: var(--color-text); }

	.nav-link:hover::after,
	.nav-link.active::after { transform: scaleX(1); }

	.nav-num {
		color: var(--color-text-faint);
		font-size: var(--text-label-sm);
	}

	.nav-sep {
		color: var(--color-text-faint);
	}

	.nav-end {
		margin-left: auto;
		flex-shrink: 0;
	}

	.theme-btn {
		background: none;
		border: none;
		cursor: pointer;
		padding: 0;
		color: var(--color-text-muted);
		transition: color var(--dur-fast) ease;
	}

	.theme-btn:hover { color: var(--color-text); }

	@media (max-width: 600px) {
		.nav-num, .nav-sep { display: none; }
		.nav-link { padding-inline: var(--space-sm); }
	}
</style>

<script>
	function initTheme() {
		const btn   = document.getElementById('theme-toggle');
		const label = document.getElementById('theme-label');
		if (!btn || !label) return;

		function currentTheme(): string {
			return (
				document.documentElement.dataset.theme ??
				(window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light')
			);
		}

		function updateLabel() {
			/* Show the mode you'll switch TO */
			label.textContent = currentTheme() === 'dark' ? 'Light' : 'Dark';
		}

		btn.addEventListener('click', () => {
			const next = currentTheme() === 'dark' ? 'light' : 'dark';
			document.documentElement.dataset.theme = next;
			localStorage.setItem('theme', next);
			updateLabel();
		});

		updateLabel();
	}

	initTheme();
	document.addEventListener('astro:page-load', initTheme);
</script>
