---
import { SITE } from '../config/site';

const year = new Date().getFullYear();
const updated = new Date().toLocaleDateString('en-GB', { month: 'short', year: 'numeric' });
---

<footer class="site-footer">

	<!-- Disclaimer row -->
	<div class="disclaimer page-wrap">
		<p class="label disclaimer-text">
			Views expressed on this site are entirely my own and do not represent
			those of my employer or any organisation I am affiliated with.
			Nothing here constitutes financial, legal, or investment advice.
			All content is provided for informational purposes only.
		</p>
	</div>

	<!-- Main footer bar -->
	<div class="page-wrap footer-inner">
		<span class="label">&copy; {year} {SITE.author}</span>
		<nav class="footer-nav" aria-label="Footer links">
			<a href="/rss.xml"          class="footer-link label">RSS</a>
			<a href={SITE.social.github}   class="footer-link label" target="_blank" rel="noopener noreferrer">GitHub ↗</a>
			<a href={SITE.social.linkedin} class="footer-link label" target="_blank" rel="noopener noreferrer">LinkedIn ↗</a>
		</nav>
		<span class="label footer-updated">Updated {updated}</span>
	</div>

</footer>

<style>
	.site-footer {
		border-top: 0.5px solid var(--color-rule);
		margin-top: auto;
	}

	/* Disclaimer */
	.disclaimer {
		padding-block: var(--space-lg);
		border-bottom: 0.5px solid var(--color-rule);
	}

	.disclaimer-text {
		color: var(--color-text-faint);
		line-height: 1.6;
		max-width: 72ch;
		letter-spacing: 0.04em; /* slightly looser for legal-ish text */
	}

	/* Main bar */
	.footer-inner {
		display: flex;
		align-items: center;
		gap: var(--space-xl);
		height: 2.875rem;
		flex-wrap: wrap;
	}

	.footer-nav {
		display: flex;
		gap: var(--space-lg);
		flex: 1;
	}

	.footer-link {
		color: var(--color-text-muted);
		transition: color var(--dur-fast) ease;
	}

	.footer-link:hover { color: var(--color-text); }

	.footer-updated { margin-left: auto; }

	@media (max-width: 600px) {
		.footer-inner   { height: auto; padding-block: var(--space-md); }
		.footer-updated { display: none; }
	}
</style>
