---
import { SITE } from '../config/site';

const year = new Date().getFullYear();
const updated = new Date().toLocaleDateString('en-GB', { month: 'short', year: 'numeric' });
---

<footer class="site-footer">
	<div class="page-wrap footer-inner">
		<span class="label">© {year} {SITE.author}</span>
		<nav class="footer-nav" aria-label="Footer links">
			<a href="/rss.xml" class="footer-link label">RSS</a>
			<a
				href={SITE.social.github}
				class="footer-link label"
				target="_blank"
				rel="noopener noreferrer"
			>GitHub ↗</a>
			<a
				href={SITE.social.linkedin}
				class="footer-link label"
				target="_blank"
				rel="noopener noreferrer"
			>LinkedIn ↗</a>
		</nav>
		<span class="label footer-updated">Updated {updated}</span>
	</div>
</footer>

<style>
	.site-footer {
		border-top: 0.5px solid var(--color-rule);
		margin-top: auto;
	}

	.footer-inner {
		display: flex;
		align-items: center;
		gap: var(--space-xl);
		height: 2.875rem;
		flex-wrap: wrap;
	}

	.footer-nav {
		display: flex;
		gap: var(--space-lg);
		flex: 1;
	}

	.footer-link {
		color: var(--color-text-muted);
		transition: color var(--dur-fast) ease;
	}

	.footer-link:hover { color: var(--color-text); }

	.footer-updated {
		margin-left: auto;
	}

	@media (max-width: 600px) {
		.footer-inner { height: auto; padding-block: var(--space-md); }
		.footer-updated { display: none; }
	}
</style>
