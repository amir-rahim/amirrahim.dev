---
import type { CollectionEntry } from 'astro:content';
import FormattedDate from './FormattedDate.astro';

interface Props {
	post: CollectionEntry<'blog'>;
	/** When true, the component renders its own border-top (for standalone lists) */
	bordered?: boolean;
}

const { post, bordered = false } = Astro.props;
const { title, description, pubDate, tags } = post.data;

/* Count words in the post body (strips markdown/MDX syntax first).
   Falls back to description word count if body is unavailable.
   Average reading speed: 200 wpm.                                  */
const bodyText   = post.body?.replace(/```[\s\S]*?```/g, '')   // remove code blocks
                             .replace(/`[^`]+`/g, '')          // remove inline code
                             .replace(/[#*_[\]()>!]/g, '')     // remove md syntax
                          ?? description ?? '';
const wordCount  = bodyText.trim().split(/\s+/).filter(Boolean).length || 80;
const readMins   = Math.max(1, Math.ceil(wordCount / 200));
---

<a
	href={`/blog/${post.id}/`}
	class:list={['post-row', { bordered }]}
	aria-label={title}
>
	<div class="post-left">
		<span class="post-title">{title}</span>
		<span class="label post-meta">
			{tags.length > 0 && tags.slice(0, 2).join(' · ')}
			{tags.length > 0 && ' · '}
			{readMins} min
		</span>
	</div>
	<time class="label post-date" datetime={pubDate.toISOString()}>
		<FormattedDate date={pubDate} />
	</time>
</a>

<style>
	.post-row {
		display: flex;
		justify-content: space-between;
		align-items: flex-start;
		gap: var(--space-xl);
		padding-block: var(--space-lg);
		border-bottom: 0.5px solid var(--color-rule);
		text-decoration: none;
		transition: opacity var(--dur-fast) ease;
	}

	.post-row.bordered {
		border-top: 0.5px solid var(--color-rule);
	}

	.post-row:hover { opacity: 0.6; }

	.post-left {
		display: flex;
		flex-direction: column;
		gap: 0.35em;
		flex: 1;
		min-width: 0;
	}

	.post-title {
		font-size: var(--text-heading);
		font-weight: var(--weight-medium);
		color: var(--color-text);
		letter-spacing: -0.01em;
		line-height: 1.3;
	}

	.post-meta {
		color: var(--color-text-muted);
	}

	.post-date {
		color: var(--color-text-muted);
		flex-shrink: 0;
		padding-top: 0.1em; /* optical align with title baseline */
	}

	@media (max-width: 600px) {
		.post-row { flex-direction: column; gap: var(--space-xs); }
		.post-date { padding-top: 0; }
	}
</style>
