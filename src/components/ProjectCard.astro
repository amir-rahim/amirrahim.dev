---
import type { CollectionEntry } from 'astro:content';

interface Props {
	project: CollectionEntry<'projects'>;
	/** Zero-based index — used for the cell number label */
	index?: number;
}

const { project, index = 0 } = Astro.props;
const { title, summary, tech, url, repo } = project.data;

const num = String(index + 1).padStart(2, '0');
---

<article class="project-cell">
	<div class="cell-header">
		<span class="label cell-num">{num}</span>
		{(url || repo) && (
			<a
				href={url ?? repo}
				class="label cell-link"
				target="_blank"
				rel="noopener noreferrer"
				aria-label={`View ${title}`}
				onclick="event.stopPropagation()"
			>↗</a>
		)}
	</div>

	<h3 class="cell-title">{title}</h3>
	<p class="cell-desc">{summary}</p>

	{tech.length > 0 && (
		<p class="label cell-tech">{tech.join(' · ')}</p>
	)}
</article>

<style>
	/* The parent grid provides borders via border-collapse technique */
	.project-cell {
		display: flex;
		flex-direction: column;
		gap: var(--space-sm);
		padding: var(--space-lg);
	}

	.cell-header {
		display: flex;
		justify-content: space-between;
		align-items: center;
		margin-bottom: var(--space-xs);
	}

	.cell-num {
		color: var(--color-text-faint);
	}

	.cell-link {
		color: var(--color-text-muted);
		font-size: var(--text-label);
		transition: color var(--dur-fast) ease;
	}

	.cell-link:hover { color: var(--color-text); }

	.cell-title {
		font-size: var(--text-body);
		font-weight: var(--weight-medium);
		color: var(--color-text);
		letter-spacing: 0;
		line-height: 1.3;
	}

	.cell-desc {
		font-size: 0.8125rem; /* 13px */
		color: var(--color-text-secondary);
		line-height: 1.55;
		max-width: none;
	}

	.cell-tech {
		color: var(--color-text-faint);
		letter-spacing: 0.05em;
		margin-top: auto;
		padding-top: var(--space-sm);
	}
</style>
