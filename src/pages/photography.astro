---
import BaseLayout from '../layouts/BaseLayout.astro';
import { SITE } from '../config/site';

interface FlickrItem {
	title: string;
	link: string;
	media: { m: string };
	date_taken: string;
	tags: string;
}

interface Photo {
	title: string;
	link: string;
	src: string;
	tags: string[];
	year: string;
}

let photos: Photo[] = [];
let fetchError = false;

try {
	const feedUrl = `https://api.flickr.com/services/feeds/photos_public.gne?id=${SITE.social.flickrNsid}&format=json&nojsoncallback=1`;
	const res = await fetch(feedUrl, { signal: AbortSignal.timeout(8000) });

	if (res.ok) {
		const data = await res.json() as { items?: FlickrItem[] };
		photos = (data.items ?? []).map((item) => ({
			title: item.title,
			link:  item.link,
			// Swap _m (240px) for _z (640px) for crisp grid display
			src:   item.media.m.replace('_m.jpg', '_z.jpg'),
			tags:  item.tags ? item.tags.split(' ').filter(Boolean) : [],
			year:  item.date_taken ? new Date(item.date_taken).getFullYear().toString() : '',
		}));
	}
} catch {
	fetchError = true;
}
---

<BaseLayout
	title="Photography"
	description={`Street photography and travel images by ${SITE.author}.`}
>
	<div class="page-wrap">

		<header class="page-header reveal">
			<p class="label header-label">Visual work</p>
			<h1 class="page-title">Photography</h1>
			<p class="page-desc">
				Street photography and travel.
				Full archive on <a href={SITE.social.flickr} target="_blank" rel="noopener noreferrer" class="flickr-link">Flickr ↗</a>.
			</p>
		</header>

	</div>

	{photos.length > 0 ? (
		<div class="photo-grid">
			{photos.map((photo) => (
				<a
					href={photo.link}
					class="photo-cell reveal"
					target="_blank"
					rel="noopener noreferrer"
					aria-label={`${photo.title} — view on Flickr`}
				>
					<div class="photo-img-wrap">
						<img
							src={photo.src}
							alt={photo.title}
							loading="lazy"
							decoding="async"
						/>
					</div>
					<div class="photo-caption">
						<span class="label photo-title">{photo.title || 'Untitled'}</span>
						{photo.year && <span class="label photo-year">{photo.year}</span>}
					</div>
				</a>
			))}
		</div>
	) : (
		<div class="page-wrap">
			<div class="doc-rows">
				<div class="doc-row">
					<span class="row-num">—</span>
					<div class="row-body">
						{fetchError ? (
							<p class="label">Could not load photos — <a href={SITE.social.flickr} target="_blank" rel="noopener noreferrer">view on Flickr ↗</a></p>
						) : (
							<p class="label">No photos yet — <a href={SITE.social.flickr} target="_blank" rel="noopener noreferrer">visit Flickr ↗</a></p>
						)}
					</div>
				</div>
			</div>
		</div>
	)}

</BaseLayout>

<style>
	/* ── Header ── */
	.page-header {
		padding-top: var(--space-2xl);
		padding-bottom: var(--space-xl);
		border-bottom: 0.5px solid var(--color-rule);
	}

	.header-label { margin-bottom: 0.4em; }

	.page-title {
		font-size: var(--text-hero);
		letter-spacing: -0.03em;
		margin-bottom: var(--space-sm);
	}

	.page-desc {
		font-size: var(--text-body);
		color: var(--color-text-muted);
		max-width: 42ch;
	}

	.flickr-link {
		color: var(--color-text);
		transition: opacity var(--dur-fast) ease;
	}

	.flickr-link:hover { opacity: 0.5; }

	/* ── Photo grid — border-collapse pattern ── */
	.photo-grid {
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		border-top: 0.5px solid var(--color-rule);
		border-left: 0.5px solid var(--color-rule);
	}

	.photo-cell {
		border-right: 0.5px solid var(--color-rule);
		border-bottom: 0.5px solid var(--color-rule);
		display: flex;
		flex-direction: column;
		text-decoration: none;
		overflow: hidden;
	}

	/* ── Image area ── */
	.photo-img-wrap {
		aspect-ratio: 3 / 2;
		overflow: hidden;
		flex-shrink: 0;
	}

	.photo-img-wrap img {
		width: 100%;
		height: 100%;
		object-fit: cover;
		display: block;
		transition: transform 500ms ease, opacity var(--dur-fast) ease;
	}

	.photo-cell:hover .photo-img-wrap img {
		transform: scale(1.04);
	}

	/* ── Caption strip ── */
	.photo-caption {
		display: flex;
		justify-content: space-between;
		align-items: center;
		padding: var(--space-sm) var(--space-md);
		border-top: 0.5px solid var(--color-rule);
		background: var(--color-bg);
		gap: var(--space-sm);
		min-height: 2.25rem;
	}

	.photo-title {
		color: var(--color-text-muted);
		overflow: hidden;
		text-overflow: ellipsis;
		white-space: nowrap;
		flex: 1;
		transition: color var(--dur-fast) ease;
	}

	.photo-cell:hover .photo-title { color: var(--color-text); }

	.photo-year {
		color: var(--color-text-faint);
		flex-shrink: 0;
	}

	/* ── Responsive ── */
	@media (max-width: 900px) {
		.photo-grid { grid-template-columns: repeat(2, 1fr); }
	}

	@media (max-width: 500px) {
		.photo-grid { grid-template-columns: 1fr; }
	}
</style>

<script>
	function shufflePhotos() {
		const grid = document.querySelector('.photo-grid');
		if (!grid) return;

		// Fisher-Yates shuffle on DOM children
		const cells = [...grid.children] as HTMLElement[];
		for (let i = cells.length - 1; i > 0; i--) {
			const j = Math.floor(Math.random() * (i + 1));
			[cells[i], cells[j]] = [cells[j], cells[i]];
		}
		// Re-append in shuffled order (appendChild moves existing nodes)
		cells.forEach((cell) => grid.appendChild(cell));
	}

	shufflePhotos();
	document.addEventListener('astro:page-load', shufflePhotos);
</script>
