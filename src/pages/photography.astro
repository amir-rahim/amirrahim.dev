---
import BaseLayout from '../layouts/BaseLayout.astro';
import { SITE } from '../config/site';
import showcaseData from '../data/showcase-photos.json';

interface ShowcasePhoto {
	id:   string;
	src:  string;
	link: string;
}

const photos = showcaseData as ShowcasePhoto[];
---

<BaseLayout
	title="Photography"
	description={`Street photography and travel images by ${SITE.author}.`}
>
	<div class="page-wrap">

		<header class="page-header reveal">
			<p class="label header-label">Visual work</p>
			<h1 class="page-title">Photography</h1>
			<p class="page-desc">
				Street photography and travel.
				Full archive on <a href={SITE.social.flickr} target="_blank" rel="noopener noreferrer" class="flickr-link">Flickr ↗</a>.
			</p>
		</header>

	</div>

	{photos.length > 0 ? (
		<div class="photo-grid">
			{photos.map((photo) => (
				<a
					href={photo.link}
					class="photo-cell reveal"
					target="_blank"
					rel="noopener noreferrer"
					aria-label={`Photo ${photo.id} — view on Flickr`}
				>
					<div class="photo-img-wrap">
						<img
							src={photo.src}
							alt=""
							loading="lazy"
							decoding="async"
						/>
					</div>
				</a>
			))}
		</div>
	) : (
		<div class="page-wrap">
			<div class="doc-rows">
				<div class="doc-row">
					<span class="row-num">—</span>
					<div class="row-body">
						<p class="label">No photos yet — <a href={SITE.social.flickr} target="_blank" rel="noopener noreferrer">visit Flickr ↗</a></p>
					</div>
				</div>
			</div>
		</div>
	)}

</BaseLayout>

<style>
	/* ── Header ── */
	.page-header {
		padding-top: var(--space-2xl);
		padding-bottom: var(--space-xl);
		border-bottom: 0.5px solid var(--color-rule);
	}

	.header-label { margin-bottom: 0.4em; }

	.page-title {
		font-size: var(--text-hero);
		letter-spacing: -0.03em;
		margin-bottom: var(--space-sm);
	}

	.page-desc {
		font-size: var(--text-body);
		color: var(--color-text-muted);
		max-width: 42ch;
	}

	.flickr-link {
		color: var(--color-text);
		transition: opacity var(--dur-fast) ease;
	}

	.flickr-link:hover { opacity: 0.5; }

	/* ── Photo grid — border-collapse pattern ── */
	.photo-grid {
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		border-top: 0.5px solid var(--color-rule);
		border-left: 0.5px solid var(--color-rule);
	}

	.photo-cell {
		border-right: 0.5px solid var(--color-rule);
		border-bottom: 0.5px solid var(--color-rule);
		display: flex;
		flex-direction: column;
		text-decoration: none;
		overflow: hidden;
	}

	/* ── Image area ── */
	.photo-img-wrap {
		aspect-ratio: 3 / 2;
		overflow: hidden;
		flex-shrink: 0;
	}

	.photo-img-wrap img {
		width: 100%;
		height: 100%;
		object-fit: cover;
		display: block;
		transition: transform 500ms ease, opacity var(--dur-fast) ease;
	}

	.photo-cell:hover .photo-img-wrap img {
		transform: scale(1.04);
	}

	/* ── Responsive ── */
	@media (max-width: 900px) {
		.photo-grid { grid-template-columns: repeat(2, 1fr); }
	}

	@media (max-width: 500px) {
		.photo-grid { grid-template-columns: 1fr; }
	}
</style>

<script>
	function shufflePhotos() {
		const grid = document.querySelector('.photo-grid');
		if (!grid) return;

		// Fisher-Yates shuffle on DOM children
		const cells = [...grid.children] as HTMLElement[];
		for (let i = cells.length - 1; i > 0; i--) {
			const j = Math.floor(Math.random() * (i + 1));
			[cells[i], cells[j]] = [cells[j], cells[i]];
		}
		// Re-append in shuffled order (appendChild moves existing nodes)
		cells.forEach((cell) => grid.appendChild(cell));
	}

	shufflePhotos();
	document.addEventListener('astro:page-load', shufflePhotos);
</script>
