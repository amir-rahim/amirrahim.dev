---
import BaseLayout from '../layouts/BaseLayout.astro';
import { resume } from '../data/resume';
---

<BaseLayout title="Resume" description={`Professional resume for ${resume.name}`}>
	<div class="container">
		<div class="resume-wrapper">

			<!-- Print button — hidden in print -->
			<div class="resume-actions no-print">
				<button onclick="window.print()" class="btn btn-ghost print-btn">
					<svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="6 9 6 2 18 2 18 9"/><path d="M6 18H4a2 2 0 0 1-2-2v-5a2 2 0 0 1 2-2h16a2 2 0 0 1 2 2v5a2 2 0 0 1-2 2h-2"/><rect width="12" height="8" x="6" y="14"/></svg>
					Print / Save PDF
				</button>
			</div>

			<!-- ── Header ── -->
			<header class="cv-header reveal">
				<div class="cv-name-block">
					<h1 class="cv-name">{resume.name}</h1>
					<p class="cv-title">{resume.title}</p>
				</div>

				<address class="cv-contact">
					<a href={`mailto:${resume.contact.email}`} class="cv-contact-item">
						<svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
						{resume.contact.email}
					</a>
					<span class="cv-contact-item">
						<svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="3"/></svg>
						{resume.contact.location}
					</span>
					<a href={`https://${resume.contact.linkedin}`} class="cv-contact-item" target="_blank" rel="noopener noreferrer">
						<svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
						{resume.contact.linkedin}
					</a>
					<a href={`https://${resume.contact.github}`} class="cv-contact-item" target="_blank" rel="noopener noreferrer">
						<svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23A11.509 11.509 0 0 1 12 5.803c1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576C20.566 21.797 24 17.3 24 12c0-6.627-5.373-12-12-12z"/></svg>
						{resume.contact.github}
					</a>
				</address>
			</header>

			<hr />

			<!-- ── Summary ── -->
			<section class="cv-section reveal" aria-labelledby="cv-summary">
				<h2 class="cv-section-heading" id="cv-summary">Summary</h2>
				<p class="cv-summary">{resume.summary}</p>
			</section>

			<hr />

			<!-- ── Experience ── -->
			<section class="cv-section reveal" aria-labelledby="cv-experience">
				<h2 class="cv-section-heading" id="cv-experience">Experience</h2>

				<div class="experience-list">
					{resume.experience.map((role) => (
						<article class="role">
							<header class="role-header">
								<div class="role-title-block">
									<h3 class="role-title">{role.title}</h3>
									<span class="role-company">{role.company}</span>
								</div>
								<div class="role-meta">
									<span class="mono-label">{role.location}</span>
									<span class="mono-label date-range">
										{role.startDate} — {role.endDate ?? 'Present'}
									</span>
								</div>
							</header>

							<ul class="role-highlights">
								{role.highlights.map((h) => (
									<li>{h}</li>
								))}
							</ul>
						</article>
					))}
				</div>
			</section>

			<hr />

			<!-- ── Education ── -->
			<section class="cv-section reveal" aria-labelledby="cv-education">
				<h2 class="cv-section-heading" id="cv-education">Education</h2>

				<div class="education-list">
					{resume.education.map((edu) => (
						<article class="edu-item">
							<div class="edu-main">
								<h3 class="edu-degree">{edu.degree}</h3>
								<span class="edu-institution">{edu.institution}</span>
								{edu.notes && <p class="edu-notes">{edu.notes}</p>}
							</div>
							<div class="edu-meta">
								<span class="mono-label">{edu.location}</span>
								<span class="mono-label">{edu.graduationYear}</span>
							</div>
						</article>
					))}
				</div>
			</section>

			<hr />

			<!-- ── Skills ── -->
			<section class="cv-section reveal" aria-labelledby="cv-skills">
				<h2 class="cv-section-heading" id="cv-skills">Skills</h2>

				<div class="skills-grid">
					{resume.skills.map((group) => (
						<div class="skill-group">
							<h4 class="skill-category">{group.category}</h4>
							<div class="skill-tags">
								{group.items.map((item) => (
									<span class="tag">{item}</span>
								))}
							</div>
						</div>
					))}
				</div>
			</section>

		</div>
	</div>
</BaseLayout>

<style>
	.resume-wrapper {
		max-width: 860px;
		margin-inline: auto;
		padding-block: var(--space-2xl);
	}

	.resume-actions {
		display: flex;
		justify-content: flex-end;
		margin-bottom: var(--space-lg);
	}

	.print-btn {
		font-size: 0.8rem;
	}

	/* ── CV Header ── */
	.cv-header {
		display: flex;
		align-items: flex-start;
		justify-content: space-between;
		gap: var(--space-xl);
		flex-wrap: wrap;
		padding-block: var(--space-lg);
	}

	.cv-name {
		font-size: clamp(2rem, 4vw, 3rem);
		letter-spacing: -0.025em;
		margin-bottom: 0.2em;
	}

	.cv-title {
		font-family: var(--font-mono);
		font-size: 0.85rem;
		color: var(--color-accent);
		letter-spacing: 0.04em;
		max-width: none;
	}

	.cv-contact {
		display: flex;
		flex-direction: column;
		gap: 0.4em;
		font-style: normal;
		text-align: right;
	}

	.cv-contact-item {
		display: flex;
		align-items: center;
		justify-content: flex-end;
		gap: 0.4em;
		font-family: var(--font-mono);
		font-size: 0.78rem;
		color: var(--color-text-muted);
		transition: color var(--dur-fast) ease;
	}

	a.cv-contact-item:hover {
		color: var(--color-accent);
	}

	/* ── Section ── */
	.cv-section {
		padding-block: var(--space-xl);
	}

	.cv-section-heading {
		font-family: var(--font-mono);
		font-size: 0.72rem;
		font-weight: 500;
		letter-spacing: 0.1em;
		text-transform: uppercase;
		color: var(--color-accent);
		margin-bottom: var(--space-lg);
	}

	.cv-summary {
		font-size: 1rem;
		line-height: 1.75;
		color: var(--color-text-muted);
		max-width: none;
	}

	/* ── Experience ── */
	.experience-list {
		display: flex;
		flex-direction: column;
		gap: var(--space-xl);
	}

	.role-header {
		display: flex;
		justify-content: space-between;
		align-items: flex-start;
		gap: var(--space-lg);
		flex-wrap: wrap;
		margin-bottom: var(--space-md);
	}

	.role-title {
		font-size: 1.05rem;
		font-weight: 700;
		letter-spacing: -0.01em;
		margin-bottom: 0.2em;
	}

	.role-company {
		font-size: 0.9rem;
		color: var(--color-text-muted);
	}

	.role-meta {
		display: flex;
		flex-direction: column;
		align-items: flex-end;
		gap: 0.2em;
	}

	.mono-label {
		font-family: var(--font-mono);
		font-size: 0.72rem;
		color: var(--color-text-faint);
		letter-spacing: 0.03em;
	}

	.date-range {
		color: var(--color-text-muted);
	}

	.role-highlights {
		list-style: none;
		display: flex;
		flex-direction: column;
		gap: 0.5em;
		padding-left: 0;
	}

	.role-highlights li {
		position: relative;
		padding-left: 1.25em;
		font-size: 0.92rem;
		color: var(--color-text-muted);
		line-height: 1.65;
	}

	.role-highlights li::before {
		content: '›';
		position: absolute;
		left: 0;
		color: var(--color-accent);
		font-weight: 600;
	}

	/* ── Education ── */
	.education-list {
		display: flex;
		flex-direction: column;
		gap: var(--space-lg);
	}

	.edu-item {
		display: flex;
		justify-content: space-between;
		align-items: flex-start;
		gap: var(--space-lg);
		flex-wrap: wrap;
	}

	.edu-degree {
		font-size: 1rem;
		font-weight: 700;
		margin-bottom: 0.2em;
	}

	.edu-institution {
		font-size: 0.9rem;
		color: var(--color-text-muted);
		display: block;
	}

	.edu-notes {
		font-size: 0.85rem;
		color: var(--color-text-faint);
		margin-top: 0.4em;
		max-width: none;
	}

	.edu-meta {
		display: flex;
		flex-direction: column;
		align-items: flex-end;
		gap: 0.2em;
	}

	/* ── Skills ── */
	.skills-grid {
		display: grid;
		grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
		gap: var(--space-lg);
	}

	.skill-category {
		font-family: var(--font-mono);
		font-size: 0.72rem;
		font-weight: 500;
		letter-spacing: 0.06em;
		text-transform: uppercase;
		color: var(--color-text-faint);
		margin-bottom: 0.6em;
	}

	.skill-tags {
		display: flex;
		flex-wrap: wrap;
		gap: 0.4em;
	}

	/* ── Print overrides ── */
	@media print {
		.resume-wrapper {
			padding-block: 0;
			max-width: 100%;
		}

		.cv-name { font-size: 1.8rem; }

		.cv-section {
			padding-block: 1.2rem;
			break-inside: avoid;
		}

		.role { break-inside: avoid; }
	}

	@media (max-width: 640px) {
		.cv-header { flex-direction: column; }
		.cv-contact { text-align: left; }
		.cv-contact-item { justify-content: flex-start; }
		.role-header { flex-direction: column; }
		.role-meta { align-items: flex-start; }
		.edu-item { flex-direction: column; }
		.edu-meta { align-items: flex-start; }
	}
</style>
