---
import BaseLayout from '../layouts/BaseLayout.astro';
import { resume } from '../data/resume';
---

<BaseLayout title="Resume" description={`CV — ${resume.name}`}>
	<div class="page-wrap">

		<!-- ── Document header ── -->
		<header class="cv-header">
			<div class="cv-title-block">
				<p class="label">Curriculum Vitae</p>
				<h1 class="cv-name">{resume.name}</h1>
				<p class="cv-role label">{resume.title}</p>
			</div>

			<address class="cv-contact">
				<a href={`mailto:${resume.contact.email}`} class="label contact-item">
					{resume.contact.email}
				</a>
				<span class="label contact-item">{resume.contact.location}</span>
				<a
					href={`https://${resume.contact.linkedin}`}
					class="label contact-item"
					target="_blank"
					rel="noopener noreferrer"
				>
					{resume.contact.linkedin} ↗
				</a>
				<a
					href={`https://${resume.contact.github}`}
					class="label contact-item"
					target="_blank"
					rel="noopener noreferrer"
				>
					{resume.contact.github} ↗
				</a>
				<a
					href={`https://amirrahim.dev`}
					class="label contact-item"
					target="_blank"
					rel="noopener noreferrer"
				>
					amirrahim.dev ↗
				</a>
			</address>
		</header>

		<!-- ── Document body ── -->
		<div class="doc-rows">

			<!-- Summary -->
			<div class="doc-row reveal">
				<span class="row-num">00</span>
				<div class="row-body">
					<h2 class="section-label label">Summary</h2>
					<p class="cv-summary">{resume.summary}</p>
				</div>
			</div>

			<!-- Experience -->
			<div class="doc-row reveal">
				<span class="row-num">01</span>
				<div class="row-body">
					<h2 class="section-label label">Experience</h2>

					<div class="entries">
						{resume.experience.map((role) => (
							<div class="entry">
								<div class="entry-head">
									<div class="entry-left">
										<span class="entry-title">{role.title}</span>
										<span class="label entry-company">{role.company} · {role.location}</span>
									</div>
									<span class="label entry-dates">
										{role.startDate} — {role.endDate ?? 'Present'}
									</span>
								</div>

								<ul class="highlights">
									{role.highlights.map((h) => (
										<li>{h}</li>
									))}
								</ul>
							</div>
						))}
					</div>
				</div>
			</div>

			<!-- Skills -->
			<div class="doc-row reveal">
				<span class="row-num">02</span>
				<div class="row-body">
					<h2 class="section-label label">Skills</h2>

					<div class="skills-grid">
						{resume.skills.map((group) => (
							<div class="skill-group">
								<span class="label skill-category">{group.category}</span>
								<p class="skill-items">{group.items.join(', ')}</p>
							</div>
						))}
					</div>
				</div>
			</div>

			<!-- Education -->
			<div class="doc-row reveal">
				<span class="row-num">03</span>
				<div class="row-body">
					<h2 class="section-label label">Education</h2>

					<div class="entries">
						{resume.education.map((edu) => (
							<div class="entry">
								<div class="entry-head">
									<div class="entry-left">
										<span class="entry-title">{edu.degree}</span>
										<span class="label entry-company">{edu.institution} · {edu.location}</span>
										{edu.notes && <p class="label edu-notes">{edu.notes}</p>}
									</div>
									<span class="label entry-dates">{edu.graduationYear}</span>
								</div>
							</div>
						))}
					</div>
				</div>
			</div>

		</div><!-- /doc-rows -->

		<!-- Print / actions -->
		<div class="cv-actions no-print">
			<button onclick="window.print()" class="btn">Print / Save PDF</button>
		</div>

	</div><!-- /page-wrap -->
</BaseLayout>

<style>
	/* ── Header ── */
	.cv-header {
		display: flex;
		justify-content: space-between;
		align-items: flex-start;
		gap: var(--space-2xl);
		padding-block: var(--space-2xl);
		border-bottom: 0.5px solid var(--color-rule);
		flex-wrap: wrap;
	}

	.cv-title-block { flex: 1; }

	.cv-header .label { margin-bottom: 0.4em; }

	.cv-name {
		font-size: clamp(1.6rem, 3vw, 2rem);
		letter-spacing: -0.025em;
		margin-bottom: 0.3em;
	}

	.cv-role {
		color: var(--color-text-muted);
	}

	.cv-contact {
		display: flex;
		flex-direction: column;
		gap: 0.3em;
		font-style: normal;
		text-align: right;
	}

	.contact-item {
		color: var(--color-text-muted);
		transition: color var(--dur-fast) ease;
	}

	a.contact-item:hover { color: var(--color-text); }

	/* ── Section label ── */
	.section-label {
		display: block;
		color: var(--color-text-muted);
		margin-bottom: var(--space-lg);
		letter-spacing: 0.1em;
	}

	/* ── Summary ── */
	.cv-summary {
		font-size: var(--text-body);
		color: var(--color-text-secondary);
		line-height: 1.7;
		max-width: 52ch;
	}

	/* ── Experience / Education entries ── */
	.entries {
		display: flex;
		flex-direction: column;
		gap: 0;
	}

	.entry {
		border-bottom: 0.5px solid var(--color-rule);
		padding-bottom: var(--space-lg);
		padding-top: var(--space-lg);
	}

	.entry:first-child { padding-top: 0; }
	.entry:last-child  { border-bottom: none; padding-bottom: 0; }

	.entry-head {
		display: flex;
		justify-content: space-between;
		align-items: flex-start;
		gap: var(--space-xl);
		margin-bottom: var(--space-sm);
		flex-wrap: wrap;
	}

	.entry-left {
		display: flex;
		flex-direction: column;
		gap: 0.25em;
	}

	.entry-title {
		font-size: var(--text-body);
		font-weight: var(--weight-medium);
		color: var(--color-text);
		line-height: 1.3;
	}

	.entry-company {
		color: var(--color-text-muted);
	}

	.edu-notes {
		color: var(--color-text-faint);
		margin-top: 0.2em;
	}

	.entry-dates {
		color: var(--color-text-muted);
		flex-shrink: 0;
		text-align: right;
	}

	.highlights {
		list-style: none;
		display: flex;
		flex-direction: column;
		gap: 0.4em;
		padding: 0;
		margin-top: var(--space-sm);
	}

	.highlights li {
		position: relative;
		padding-left: 1.1em;
		font-size: var(--text-body);
		color: var(--color-text-secondary);
		line-height: 1.6;
	}

	.highlights li::before {
		content: '—';
		position: absolute;
		left: 0;
		color: var(--color-text-faint);
	}

	/* ── Skills ── */
	.skills-grid {
		display: grid;
		grid-template-columns: repeat(auto-fill, minmax(180px, 1fr));
		gap: var(--space-lg);
	}

	.skill-group {
		display: flex;
		flex-direction: column;
		gap: 0.35em;
	}

	.skill-category {
		color: var(--color-text-muted);
	}

	.skill-items {
		font-size: var(--text-body);
		color: var(--color-text-secondary);
		line-height: 1.55;
		max-width: none;
	}

	/* ── Actions ── */
	.cv-actions {
		display: flex;
		justify-content: flex-end;
		padding-block: var(--space-xl);
		border-top: 0.5px solid var(--color-rule);
	}

	/* ── Print ── */
	@media print {
		.cv-header {
			padding-block: 0.75rem;
			border-bottom: 0.5px solid #ccc;
		}
		.cv-name    { font-size: 18pt; letter-spacing: -0.02em; }
		.cv-role    { font-size: 8pt; }
		.cv-summary { font-size: 9pt; max-width: none; }
		.entry-title { font-size: 9pt; }
		.highlights li { font-size: 9pt; }
		.skill-items { font-size: 9pt; }
		.skills-grid { grid-template-columns: repeat(3, 1fr); gap: 0.5rem; }
		.doc-rows { border-color: #ccc; }
		.row-body { padding: 0.5rem 0.75rem; }
	}

	@media (max-width: 640px) {
		.cv-header { flex-direction: column; gap: var(--space-lg); }
		.cv-contact { text-align: left; }
		.entry-head { flex-direction: column; gap: var(--space-xs); }
		.entry-dates { text-align: left; }
	}
</style>
