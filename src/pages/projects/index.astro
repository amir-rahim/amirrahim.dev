---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import ProjectCard from '../../components/ProjectCard.astro';

const projects = (await getCollection('projects'))
	.filter((p) => !p.data.draft)
	.sort((a, b) => a.data.order - b.data.order);
---

<BaseLayout
	title="Projects"
	description="A showcase of selected engineering projects — systems, tools, and experiments."
>
	<div class="page-wrap">

		<!-- Page header -->
		<header class="page-header">
			<p class="label header-label">Work</p>
			<h1 class="page-title">Projects</h1>
			<p class="page-desc">
				Selected engineering work — systems built, problems solved, things learned.
			</p>
		</header>

		<!-- 2-col specimen grid — borders form the cells -->
		{projects.length > 0 ? (
			<div class="project-grid">
				{projects.map((project, i) => (
					<ProjectCard project={project} index={i} />
				))}
			</div>
		) : (
			<div class="doc-rows">
				<div class="doc-row">
					<span class="row-num">—</span>
					<div class="row-body">
						<p class="label">Projects coming soon.</p>
					</div>
				</div>
			</div>
		)}

	</div>
</BaseLayout>

<style>
	.page-header {
		padding-top: var(--space-2xl);
		padding-bottom: var(--space-xl);
		border-bottom: 0.5px solid var(--color-rule);
	}

	.header-label { margin-bottom: 0.4em; }

	.page-title {
		font-size: var(--text-hero);
		letter-spacing: -0.03em;
		margin-bottom: var(--space-sm);
	}

	.page-desc {
		font-size: var(--text-body);
		color: var(--color-text-muted);
		max-width: 42ch;
	}

	/* Specimen grid — lines as cells */
	.project-grid {
		display: grid;
		grid-template-columns: 1fr 1fr;
		border-top: 0.5px solid var(--color-rule);
		border-left: 0.5px solid var(--color-rule);
		margin-bottom: var(--space-3xl);
	}

	.project-grid > :global(.project-cell) {
		border-right: 0.5px solid var(--color-rule);
		border-bottom: 0.5px solid var(--color-rule);
		transition: background var(--dur-fast) ease;
	}

	.project-grid > :global(.project-cell:hover) {
		background: var(--color-surface);
	}

	@media (max-width: 600px) {
		.project-grid { grid-template-columns: 1fr; }
	}
</style>
