---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import BlogCard from '../components/BlogCard.astro';
import ProjectCard from '../components/ProjectCard.astro';
import { SITE } from '../config/site';

const allPosts = (await getCollection('blog'))
	.filter((p) => !p.data.draft)
	.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
	.slice(0, 4);

const featuredProjects = (await getCollection('projects'))
	.filter((p) => !p.data.draft && p.data.featured)
	.sort((a, b) => a.data.order - b.data.order)
	.slice(0, 4);

/* EDIT: the large statement shown on slide 2 of the hero */
const statement = {
	lines: [
		'Building the infrastructure',
		'engineers rely on.',
	],
	current: 'Graduate Rotation · UBS · London, UK',
	tags: ['Infrastructure', 'Platform Engineering', 'Developer Experience'],
};
---

<BaseLayout title={SITE.title} description={SITE.description}>

	<!--
		Hero is 260vh tall. The inner panel is sticky so both slides
		play out in the viewport before the page scrolls to content below.

		Timeline (scroll progress 0 → 1):
		  0.00–0.30  Slide 1 fully visible
		  0.30–0.48  Slide 1 fades & lifts out
		  0.48–0.55  Both hidden — canvas floods (dramatic transition)
		  0.55–0.68  Slide 2 rises in
		  0.68–0.84  Slide 2 fully visible
		  0.84–0.98  Slide 2 fades & lifts out
		  1.00        Hero releases, projects/blog appear
	-->
	<section class="hero" id="hero" aria-label="Introduction">
		<canvas id="hero-canvas" class="hero-canvas" aria-hidden="true"></canvas>

		<div class="hero-sticky">

			<!-- Progress bar: fills across the bottom as you scroll -->
			<div class="hero-progress" aria-hidden="true">
				<div class="hero-progress-bar" id="hero-progress-bar"></div>
			</div>

			<!-- Slide 1: name / intro -->
			<div class="hero-slide" id="slide-1" aria-hidden="false">
				<div class="page-wrap slide-content">
					<p class="label slide-eyebrow">Software Engineer</p>
					<h1 class="hero-name">{SITE.author}</h1>
					<p class="hero-tagline">{SITE.description}</p>
					<div class="hero-actions">
						<a href="/resume" class="btn">View Resume</a>
						<a href={SITE.social.github}   class="btn" target="_blank" rel="noopener noreferrer">GitHub &nearr;</a>
						<a href={SITE.social.linkedin} class="btn" target="_blank" rel="noopener noreferrer">LinkedIn &nearr;</a>
						<a href={`mailto:${SITE.social.email}`} class="btn">Email</a>
					</div>
				</div>
			</div>

			<!-- Slide 2: large typographic statement -->
			<div class="hero-slide" id="slide-2" aria-hidden="true" style="opacity:0;pointer-events:none">
				<div class="page-wrap slide-content">
					<p class="label slide-eyebrow">Currently</p>

					<div class="statement-block">
						{statement.lines.map((line) => (
							<span class="statement-line">{line}</span>
						))}
					</div>

					<div class="statement-meta">
						<span class="label statement-role">{statement.current}</span>
						<div class="statement-tags">
							{statement.tags.map((tag) => (
								<span class="statement-tag label">{tag}</span>
							))}
						</div>
					</div>
				</div>
			</div>

			<!-- Scroll hint: vertical scan line centred at bottom -->
			<div class="scroll-hint" id="scroll-hint" aria-hidden="true">
				<div class="scroll-line"></div>
				<span class="label">Scroll</span>
			</div>

		</div>
	</section>

	<!-- Projects + Blog -->
	<div class="page-wrap">
		<div class="doc-rows">

			{featuredProjects.length > 0 && (
				<div class="doc-row reveal">
					<span class="row-num">01</span>
					<div class="row-body">
						<div class="section-head">
							<span class="label">Selected work</span>
							<h2 class="section-title">Projects</h2>
						</div>
						<div class="project-grid">
							{featuredProjects.map((project, i) => (
								<ProjectCard project={project} index={i} />
							))}
						</div>
						<a href="/projects" class="section-more label">All projects &rarr;</a>
					</div>
				</div>
			)}

			{allPosts.length > 0 && (
				<div class="doc-row reveal">
					<span class="row-num">02</span>
					<div class="row-body">
						<div class="section-head">
							<span class="label">Writing</span>
							<h2 class="section-title">Latest posts</h2>
						</div>
						<div class="posts-list">
							{allPosts.map((post) => (
								<BlogCard post={post} />
							))}
						</div>
						<a href="/blog" class="section-more label">All posts &rarr;</a>
					</div>
				</div>
			)}

		</div>
	</div>

</BaseLayout>

<style>
	/* ── Hero shell — tall enough for two slides ── */
	.hero {
		position: relative;
		min-height: 260vh;
	}

	/* ── Sticky viewport panel ── */
	.hero-sticky {
		position: sticky;
		top: 0;
		height: 100dvh;
		overflow: hidden;
		border-bottom: 0.5px solid var(--color-rule);
	}

	/* ── Canvas ── */
	.hero-canvas {
		position: absolute;
		inset: 0;
		width: 100%;
		height: 100%;
		display: block;
	}

	/* ── Both slides: full-area, stacked, JS controls opacity ── */
	.hero-slide {
		position: absolute;
		inset: 0;
		display: flex;
		align-items: center;
		will-change: opacity, transform;
	}

	.slide-content {
		position: relative;
		z-index: 1;
	}

	.slide-eyebrow { margin-bottom: var(--space-lg); }

	/* Slide 1 */
	.hero-name   { margin-bottom: var(--space-md); }

	.hero-tagline {
		font-size: var(--text-body);
		color: var(--color-text-secondary);
		line-height: 1.7;
		max-width: 52ch;
		margin-bottom: var(--space-xl);
	}

	.hero-actions {
		display: flex;
		flex-wrap: wrap;
		gap: var(--space-sm);
	}

	/* Slide 2: typographic statement */
	.statement-block {
		display: flex;
		flex-direction: column;
		margin-top: var(--space-md);
		margin-bottom: var(--space-2xl);
	}

	.statement-line {
		font-size: clamp(2rem, 5vw, 3.75rem);
		font-weight: var(--weight-medium);
		letter-spacing: -0.03em;
		line-height: 1.1;
		color: var(--color-text);
	}

	.statement-meta {
		border-top: 0.5px solid var(--color-rule);
		padding-top: var(--space-lg);
		display: flex;
		flex-direction: column;
		gap: var(--space-md);
	}

	.statement-role { color: var(--color-text-muted); }

	.statement-tags {
		display: flex;
		flex-wrap: wrap;
		gap: var(--space-sm);
	}

	.statement-tag {
		border: 0.5px solid var(--color-rule);
		padding: 0.25em 0.75em;
		color: var(--color-text-faint);
	}

	/* ── Progress bar ── */
	.hero-progress {
		position: absolute;
		bottom: 0;
		left: 0;
		right: 0;
		height: 1.5px;
		background: var(--color-rule);
		z-index: 10;
	}

	.hero-progress-bar {
		height: 100%;
		width: 0%;
		background: var(--color-rule-heavy);
	}

	/* ── Scroll hint ── */
	.scroll-hint {
		position: absolute;
		bottom: var(--space-xl);
		left: 50%;
		transform: translateX(-50%);
		z-index: 10;
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 0.5rem;
		transition: opacity 400ms ease;
		white-space: nowrap;
	}

	.scroll-hint .label { color: var(--color-text-muted); }

	.scroll-line {
		width: 1px;
		height: 32px;
		background: var(--color-rule);
		position: relative;
		overflow: hidden;
	}

	.scroll-line::after {
		content: '';
		position: absolute;
		inset: 0;
		background: var(--color-rule-heavy);
		transform: translateY(-100%);
		animation: scan-down 1.8s ease-in-out infinite;
	}

	@keyframes scan-down {
		0%   { transform: translateY(-100%); }
		50%  { transform: translateY(0%); }
		100% { transform: translateY(100%); }
	}

	/* ── Section chrome ── */
	.section-head { margin-bottom: var(--space-md); }
	.section-head .label { display: block; margin-bottom: 0.3em; }

	.section-title {
		font-size: var(--text-heading);
		font-weight: var(--weight-medium);
		letter-spacing: -0.01em;
	}

	.section-more {
		display: inline-block;
		margin-top: var(--space-md);
		color: var(--color-text-muted);
		transition: color var(--dur-fast) ease;
	}

	.section-more:hover { color: var(--color-text); }

	/* ── Project grid ── */
	.project-grid {
		display: grid;
		grid-template-columns: 1fr 1fr;
		border-top: 0.5px solid var(--color-rule);
		border-left: 0.5px solid var(--color-rule);
	}

	.project-grid > :global(.project-cell) {
		border-right: 0.5px solid var(--color-rule);
		border-bottom: 0.5px solid var(--color-rule);
		transition: background var(--dur-fast) ease;
	}

	.project-grid > :global(.project-cell:hover) {
		background: var(--color-surface);
	}

	.posts-list { border-top: 0.5px solid var(--color-rule); }

	@media (max-width: 600px) {
		.project-grid  { grid-template-columns: 1fr; }
		.statement-line { font-size: clamp(1.6rem, 8vw, 2.5rem); }
	}

	@media (prefers-reduced-motion: reduce) {
		.scroll-line::after { animation: none; }
		.hero-slide { transition: none !important; }
	}
</style>

<script>
	/* ── Scroll driver ───────────────────────────────────────────────── */
	function initHeroScroll() {
		const hero        = document.getElementById('hero');
		const slide1      = document.getElementById('slide-1');
		const slide2      = document.getElementById('slide-2');
		const progressBar = document.getElementById('hero-progress-bar');
		const scrollHint  = document.getElementById('scroll-hint');
		if (!hero || !slide1 || !slide2) return;

		const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

		/* Clamp a value between 0 and 1 */
		function clamp(v: number) { return Math.max(0, Math.min(1, v)); }

		/* Map a progress range to 0→1 */
		function range(p: number, from: number, to: number) {
			return clamp((p - from) / (to - from));
		}

		function ease(t: number) { return t * t; } /* ease-in */

		function applySlide(
			el: HTMLElement,
			opacity: number,
			translateY: number,
		) {
			el.style.opacity        = String(opacity);
			el.style.transform      = `translateY(${translateY}px)`;
			el.style.pointerEvents  = opacity < 0.05 ? 'none' : 'auto';
			el.setAttribute('aria-hidden', String(opacity < 0.05));
		}

		function onScroll() {
			const rect       = hero.getBoundingClientRect();
			const scrollable = hero.offsetHeight - window.innerHeight;
			const scrolled   = Math.max(0, -rect.top);
			const p          = scrollable > 0 ? clamp(scrolled / scrollable) : 0;

			/* Expose to canvas */
			(window as any).__heroProgress = p;

			/* Progress bar */
			if (progressBar) progressBar.style.width = `${p * 100}%`;

			/* Scroll hint */
			if (scrollHint) scrollHint.style.opacity = p < 0.04 ? '1' : '0';

			if (reduced) return;

			/*
			 * Slide 1: visible 0→0.30, fades & lifts 0.30→0.48
			 */
			const s1Opacity = 1 - ease(range(p, 0.30, 0.48));
			const s1Y       = -ease(range(p, 0.30, 0.48)) * 42;
			applySlide(slide1, s1Opacity, s1Y);

			/*
			 * Slide 2: rises in 0.55→0.68, fully visible 0.68→0.84,
			 *           fades & lifts 0.84→0.98
			 */
			const enterT    = range(p, 0.55, 0.68);
			const exitT     = ease(range(p, 0.84, 0.98));
			const s2Opacity = enterT * (1 - exitT);
			const s2Y       = (1 - enterT) * 36 - exitT * 42;
			applySlide(slide2, clamp(s2Opacity), s2Y);
		}

		window.addEventListener('scroll', onScroll, { passive: true });
		onScroll();

		const cleanup = () => {
			window.removeEventListener('scroll', onScroll);
			document.removeEventListener('astro:before-swap', cleanup);
		};
		document.addEventListener('astro:before-swap', cleanup);
	}

	initHeroScroll();
	document.addEventListener('astro:page-load', initHeroScroll);


	/* ── 8-bit canvas ────────────────────────────────────────────────── */
	function initHeroCanvas() {
		const canvas = document.getElementById('hero-canvas') as HTMLCanvasElement | null;
		if (!canvas) return;
		const ctx = canvas.getContext('2d');
		if (!ctx) return;
		if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;

		const CELL      = 18;
		const CHARS     = ['0','1','0','1','0','1','+','·','×','-','0','1'];
		const BASE_FILL = 0.04;
		const FPS       = 22;
		const INTERVAL  = 1000 / FPS;

		function getMaxOpacity(): number {
			const theme      = document.documentElement.dataset.theme;
			const prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
			return (theme === 'dark' || (!theme && prefersDark)) ? 0.20 : 0.55;
		}

		interface Cell {
			x: number; y: number;
			char: string;
			opacity: number;
			target: number;
			speed: number;
			ticksLeft: number;
		}

		let cells: Cell[] = [];
		let raf = 0;
		let last = 0;

		function getCssColor(prop: string) {
			return getComputedStyle(document.documentElement).getPropertyValue(prop).trim();
		}

		function resize() {
			canvas.width  = canvas.offsetWidth;
			canvas.height = canvas.offsetHeight;
			buildCells();
		}

		function buildCells() {
			cells = [];
			const cols = Math.ceil(canvas.width  / CELL) + 1;
			const rows = Math.ceil(canvas.height / CELL) + 1;
			for (let r = 0; r < rows; r++) {
				for (let c = 0; c < cols; c++) {
					cells.push({
						x: c * CELL, y: r * CELL,
						char: CHARS[Math.floor(Math.random() * CHARS.length)],
						opacity: 0, target: 0,
						speed: 0.06 + Math.random() * 0.1,
						ticksLeft: Math.floor(Math.random() * FPS * 3),
					});
				}
			}
		}

		function tickCells() {
			const progress    = (window as any).__heroProgress ?? 0;
			/* Density peaks in the blackout window (both slides hidden ~0.48-0.55) */
			const spike       = 1 - Math.abs(progress - 0.515) / 0.515;
			const densityMult = 1 + Math.pow(spike, 2) * 7;
			const wantActive  = Math.ceil(cells.length * BASE_FILL * densityMult);
			const maxOp       = getMaxOpacity();

			for (const cell of cells) {
				cell.opacity += (cell.target - cell.opacity) * cell.speed;

				if (cell.ticksLeft > 0) { cell.ticksLeft--; continue; }

				cell.opacity = cell.target;

				if (cell.target > 0) {
					cell.target    = 0;
					cell.ticksLeft = Math.floor(FPS * (1 + Math.random() * 6));
				} else {
					if (Math.random() < wantActive / cells.length) {
						cell.target    = maxOp * (0.25 + Math.random() * 0.75);
						cell.char      = CHARS[Math.floor(Math.random() * CHARS.length)];
						cell.ticksLeft = Math.floor(FPS * (0.4 + Math.random() * 2));
					} else {
						cell.ticksLeft = Math.floor(FPS * (0.2 + Math.random() * 2));
					}
				}
			}
		}

		function draw() {
			ctx.clearRect(0, 0, canvas.width, canvas.height);
			const color = getCssColor('--color-text');
			ctx.font = `${Math.round(CELL * 0.62)}px 'JetBrains Mono', monospace`;
			ctx.textAlign = 'center'; ctx.textBaseline = 'middle';

			for (const cell of cells) {
				const op = Math.abs(cell.opacity);
				if (op < 0.005) continue;
				ctx.globalAlpha = op;
				ctx.fillStyle   = color;
				ctx.fillText(cell.char, cell.x + CELL / 2, cell.y + CELL / 2);
			}
			ctx.globalAlpha = 1;
		}

		function loop(ts: number) {
			raf = requestAnimationFrame(loop);
			if (ts - last < INTERVAL) return;
			last = ts;
			tickCells();
			draw();
		}

		const ro = new ResizeObserver(resize);
		ro.observe(canvas);
		resize();
		raf = requestAnimationFrame(loop);

		const cleanup = () => {
			cancelAnimationFrame(raf);
			ro.disconnect();
			document.removeEventListener('astro:before-swap', cleanup);
		};
		document.addEventListener('astro:before-swap', cleanup);
	}

	initHeroCanvas();
	document.addEventListener('astro:page-load', initHeroCanvas);
</script>
