---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import BlogCard from '../components/BlogCard.astro';
import ProjectCard from '../components/ProjectCard.astro';
import { SITE } from '../config/site';

const allPosts = (await getCollection('blog'))
	.filter((p) => !p.data.draft)
	.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
	.slice(0, 4);

const featuredProjects = (await getCollection('projects'))
	.filter((p) => !p.data.draft && p.data.featured)
	.sort((a, b) => a.data.order - b.data.order)
	.slice(0, 4);
---

<BaseLayout title={SITE.title} description={SITE.description}>
	<div class="page-wrap">

		<!-- ── Hero ──────────────────────────────────────────────────── -->
		<section class="hero" aria-label="Introduction">
			<p class="label hero-label">Software Engineer</p>

			<h1 class="hero-name">{SITE.author}</h1>

			<p class="hero-tagline">
				{SITE.description}
			</p>

			<div class="hero-actions">
				<a href="/resume" class="btn">View Resume</a>
				<a
					href={SITE.social.github}
					class="btn"
					target="_blank"
					rel="noopener noreferrer"
				>GitHub ↗</a>
				<a
					href={SITE.social.linkedin}
					class="btn"
					target="_blank"
					rel="noopener noreferrer"
				>LinkedIn ↗</a>
				<a href={`mailto:${SITE.social.email}`} class="btn">Email</a>
			</div>
		</section>

		<!-- ── Numbered content sections ─────────────────────────────── -->
		<div class="doc-rows">

			<!-- 01 — Projects -->
			{featuredProjects.length > 0 && (
				<div class="doc-row reveal">
					<span class="row-num">01</span>
					<div class="row-body">
						<div class="section-head">
							<span class="label">Selected work</span>
							<h2 class="section-title">Projects</h2>
						</div>

						<!-- 2-col grid: borders form the cells -->
						<div class="project-grid">
							{featuredProjects.map((project, i) => (
								<ProjectCard project={project} index={i} />
							))}
						</div>

						<a href="/projects" class="section-more label">
							All projects →
						</a>
					</div>
				</div>
			)}

			<!-- 02 — Writing -->
			{allPosts.length > 0 && (
				<div class="doc-row reveal">
					<span class="row-num">02</span>
					<div class="row-body">
						<div class="section-head">
							<span class="label">Writing</span>
							<h2 class="section-title">Latest posts</h2>
						</div>

						<div class="posts-list">
							{allPosts.map((post) => (
								<BlogCard post={post} />
							))}
						</div>

						<a href="/blog" class="section-more label">
							All posts →
						</a>
					</div>
				</div>
			)}

		</div><!-- /doc-rows -->
	</div><!-- /page-wrap -->
</BaseLayout>

<style>
	/* ── Hero ── */
	.hero {
		padding-top: var(--space-3xl);
		padding-bottom: var(--space-2xl);
		border-bottom: 0.5px solid var(--color-rule);
		max-width: 640px;
	}

	.hero-label {
		margin-bottom: var(--space-lg);
	}

	.hero-name {
		margin-bottom: var(--space-md);
	}

	.hero-tagline {
		font-size: var(--text-body);
		color: var(--color-text-secondary);
		line-height: 1.7;
		max-width: 42ch;
		margin-bottom: var(--space-xl);
	}

	.hero-actions {
		display: flex;
		flex-wrap: wrap;
		gap: var(--space-sm);
	}

	/* ── Section chrome ── */
	.section-head {
		margin-bottom: var(--space-lg);
	}

	.section-head .label {
		display: block;
		margin-bottom: 0.3em;
	}

	.section-title {
		font-size: var(--text-heading);
		font-weight: var(--weight-medium);
		letter-spacing: -0.01em;
	}

	.section-more {
		display: inline-block;
		margin-top: var(--space-lg);
		color: var(--color-text-muted);
		transition: color var(--dur-fast) ease;
	}

	.section-more:hover { color: var(--color-text); }

	/* ── Project grid — borders form cells ── */
	.project-grid {
		display: grid;
		grid-template-columns: 1fr 1fr;
		border-top: 0.5px solid var(--color-rule);
		border-left: 0.5px solid var(--color-rule);
	}

	.project-grid > :global(.project-cell) {
		border-right: 0.5px solid var(--color-rule);
		border-bottom: 0.5px solid var(--color-rule);
		transition: background var(--dur-fast) ease;
	}

	.project-grid > :global(.project-cell:hover) {
		background: var(--color-surface);
	}

	/* ── Posts list ── */
	.posts-list {
		border-top: 0.5px solid var(--color-rule);
	}

	@media (max-width: 600px) {
		.project-grid { grid-template-columns: 1fr; }
		.hero { padding-top: var(--space-2xl); }
	}
</style>
