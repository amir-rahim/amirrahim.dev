---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import BlogCard from '../components/BlogCard.astro';
import ProjectCard from '../components/ProjectCard.astro';
import { SITE } from '../config/site';

const allPosts = (await getCollection('blog'))
	.filter((p) => !p.data.draft)
	.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
	.slice(0, 3);

const featuredProjects = (await getCollection('projects'))
	.filter((p) => !p.data.draft && p.data.featured)
	.sort((a, b) => a.data.order - b.data.order)
	.slice(0, 3);
---

<BaseLayout title={SITE.title} description={SITE.description}>
	<!-- ── Hero ─────────────────────────────────────────────────────── -->
	<section class="hero" aria-label="Introduction">
		<div class="aurora" aria-hidden="true">
			<div class="aurora-orb orb-1"></div>
			<div class="aurora-orb orb-2"></div>
			<div class="aurora-orb orb-3"></div>
		</div>

		<div class="container hero-inner">
			<div class="hero-eyebrow">
				<span class="mono-chip">Software Engineer</span>
			</div>

			<h1 class="hero-name">
				PLACEHOLDER<br />
				<span class="name-accent">FULL NAME</span>
			</h1>

			<p class="hero-tagline">
				PLACEHOLDER — One confident line about what you do and who you do it
				for. E.g. "Engineering reliable, high-throughput systems at the
				intersection of software and financial markets."
			</p>

			<div class="hero-actions">
				<a href="/resume" class="btn btn-primary">View Resume</a>
				<a href="/projects" class="btn btn-ghost">See Projects</a>
			</div>

			<div class="hero-links">
				<a
					href={SITE.social.github}
					class="social-pill"
					target="_blank"
					rel="noopener noreferrer"
				>
					<svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23A11.509 11.509 0 0 1 12 5.803c1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576C20.566 21.797 24 17.3 24 12c0-6.627-5.373-12-12-12z"/></svg>
					GitHub
				</a>
				<a
					href={SITE.social.linkedin}
					class="social-pill"
					target="_blank"
					rel="noopener noreferrer"
				>
					<svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
					LinkedIn
				</a>
				<a href={`mailto:${SITE.social.email}`} class="social-pill">
					<svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
					Email
				</a>
			</div>
		</div>
	</section>

	<!-- ── Featured Projects ────────────────────────────────────────── -->
	{featuredProjects.length > 0 && (
		<section class="section container" aria-labelledby="projects-heading">
			<div class="section-header reveal">
				<span class="section-label">Selected work</span>
				<h2 id="projects-heading">Projects</h2>
			</div>

			<div class="projects-grid stagger">
				{featuredProjects.map((project) => (
					<ProjectCard project={project} />
				))}
			</div>

			<div class="section-cta reveal">
				<a href="/projects" class="btn btn-ghost">
					All projects
					<svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
				</a>
			</div>
		</section>
	)}

	<!-- ── Latest Posts ─────────────────────────────────────────────── -->
	{allPosts.length > 0 && (
		<section class="section container" aria-labelledby="blog-heading">
			<div class="section-header reveal">
				<span class="section-label">Writing</span>
				<h2 id="blog-heading">Latest posts</h2>
			</div>

			<div class="blog-grid stagger">
				{allPosts.map((post, i) => (
					<BlogCard post={post} featured={i === 0} />
				))}
			</div>

			<div class="section-cta reveal">
				<a href="/blog" class="btn btn-ghost">
					All posts
					<svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
				</a>
			</div>
		</section>
	)}
</BaseLayout>

<style>
	/* ── Hero ── */
	.hero {
		position: relative;
		min-height: min(90svh, 800px);
		display: flex;
		align-items: center;
		overflow: hidden;
	}

	.aurora {
		position: absolute;
		inset: 0;
		pointer-events: none;
	}

	.aurora-orb {
		position: absolute;
		border-radius: 50%;
		filter: blur(80px);
		will-change: transform;
	}

	.orb-1 {
		width: 55%;
		height: 60%;
		background: var(--color-accent-glow);
		top: -15%;
		left: -10%;
		opacity: 0.6;
		animation: aurora-1 14s ease-in-out infinite alternate;
	}

	.orb-2 {
		width: 35%;
		height: 40%;
		background: hsla(190 100% 58% / 0.12);
		bottom: 0;
		right: 5%;
		opacity: 0.7;
		animation: aurora-2 18s ease-in-out infinite alternate;
	}

	.orb-3 {
		width: 25%;
		height: 30%;
		background: hsla(240 100% 65% / 0.08);
		top: 40%;
		right: 25%;
		opacity: 0.6;
		animation: aurora-3 11s ease-in-out infinite alternate;
	}

	@keyframes aurora-1 {
		from { transform: translate(0, 0) scale(1); }
		to   { transform: translate(40px, 30px) scale(1.08); }
	}
	@keyframes aurora-2 {
		from { transform: translate(0, 0) scale(1); }
		to   { transform: translate(-30px, -25px) scale(0.92); }
	}
	@keyframes aurora-3 {
		from { transform: translate(0, 0) scale(1); }
		to   { transform: translate(25px, -35px) scale(1.12); }
	}

	@media (prefers-reduced-motion: reduce) {
		.aurora-orb { animation: none; }
	}

	.hero-inner {
		position: relative;
		z-index: 1;
		padding-block: var(--space-3xl);
		max-width: 760px;
	}

	.hero-eyebrow {
		margin-bottom: var(--space-lg);
	}

	.mono-chip {
		font-family: var(--font-mono);
		font-size: 0.72rem;
		font-weight: 500;
		letter-spacing: 0.1em;
		text-transform: uppercase;
		color: var(--color-accent);
		background: var(--color-accent-dim);
		border: 1px solid var(--color-accent-glow);
		padding: 0.35em 0.8em;
		border-radius: 20px;
	}

	.hero-name {
		font-size: clamp(3rem, 8vw, 6rem);
		font-weight: 800;
		line-height: 1.05;
		letter-spacing: -0.03em;
		margin-bottom: var(--space-lg);
	}

	.name-accent {
		color: var(--color-accent);
	}

	.hero-tagline {
		font-size: clamp(1rem, 1.5vw, 1.2rem);
		color: var(--color-text-muted);
		line-height: 1.7;
		margin-bottom: var(--space-xl);
		max-width: 58ch;
	}

	.hero-actions {
		display: flex;
		gap: var(--space-sm);
		flex-wrap: wrap;
		margin-bottom: var(--space-xl);
	}

	.hero-links {
		display: flex;
		align-items: center;
		gap: var(--space-sm);
		flex-wrap: wrap;
	}

	.social-pill {
		display: inline-flex;
		align-items: center;
		gap: 0.4em;
		font-family: var(--font-mono);
		font-size: 0.75rem;
		font-weight: 500;
		letter-spacing: 0.03em;
		color: var(--color-text-muted);
		border: 1px solid var(--color-border);
		padding: 0.4em 0.8em;
		border-radius: 20px;
		transition:
			color var(--dur-fast) ease,
			border-color var(--dur-fast) ease,
			background var(--dur-fast) ease;
	}

	.social-pill:hover {
		color: var(--color-text);
		border-color: var(--color-accent-dim);
		background: var(--color-accent-dim);
	}

	/* ── Section chrome ── */
	.section-header {
		margin-bottom: var(--space-xl);
	}

	.section-label {
		font-family: var(--font-mono);
		font-size: 0.72rem;
		font-weight: 500;
		letter-spacing: 0.1em;
		text-transform: uppercase;
		color: var(--color-accent);
		display: block;
		margin-bottom: 0.5em;
	}

	.projects-grid,
	.blog-grid {
		display: grid;
		grid-template-columns: repeat(auto-fill, minmax(min(100%, 300px), 1fr));
		gap: var(--space-lg);
	}

	.section-cta {
		margin-top: var(--space-xl);
	}
</style>
