---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import BlogCard from '../components/BlogCard.astro';
import ProjectCard from '../components/ProjectCard.astro';
import { SITE } from '../config/site';

const allPosts = (await getCollection('blog'))
	.filter((p) => !p.data.draft)
	.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
	.slice(0, 4);

const featuredProjects = (await getCollection('projects'))
	.filter((p) => !p.data.draft && p.data.featured)
	.sort((a, b) => a.data.order - b.data.order)
	.slice(0, 4);
---

<BaseLayout title={SITE.title} description={SITE.description}>

	<!--
		Hero is 200vh tall. The inner panel is sticky so it pins to the
		top while you scroll through, then releases when you reach the
		content below.
	-->
	<section class="hero" id="hero" aria-label="Introduction">
		<canvas id="hero-canvas" class="hero-canvas" aria-hidden="true"></canvas>

		<div class="hero-sticky">
			<!-- Progress bar — fills left→right as you scroll through the hero -->
			<div class="hero-progress" aria-hidden="true">
				<div class="hero-progress-bar" id="hero-progress-bar"></div>
			</div>

			<div class="hero-inner page-wrap" id="hero-inner">
				<p class="label hero-label">Software Engineer</p>
				<h1 class="hero-name">{SITE.author}</h1>
				<p class="hero-tagline">{SITE.description}</p>

				<div class="hero-actions">
					<a href="/resume" class="btn">View Resume</a>
					<a
						href={SITE.social.github}
						class="btn"
						target="_blank"
						rel="noopener noreferrer"
					>GitHub &nearr;</a>
					<a
						href={SITE.social.linkedin}
						class="btn"
						target="_blank"
						rel="noopener noreferrer"
					>LinkedIn &nearr;</a>
					<a href={`mailto:${SITE.social.email}`} class="btn">Email</a>
				</div>
			</div>

			<!-- Scroll hint — fades once scrolling starts -->
			<div class="scroll-hint" id="scroll-hint" aria-hidden="true">
				<div class="scroll-line"></div>
				<span class="label">Scroll</span>
			</div>
		</div>
	</section>

	<!-- Content rows sit below the 200vh hero -->
	<div class="page-wrap">
		<div class="doc-rows">

			{featuredProjects.length > 0 && (
				<div class="doc-row reveal">
					<span class="row-num">01</span>
					<div class="row-body">
						<div class="section-head">
							<span class="label">Selected work</span>
							<h2 class="section-title">Projects</h2>
						</div>

						<div class="project-grid">
							{featuredProjects.map((project, i) => (
								<ProjectCard project={project} index={i} />
							))}
						</div>

						<a href="/projects" class="section-more label">All projects &rarr;</a>
					</div>
				</div>
			)}

			{allPosts.length > 0 && (
				<div class="doc-row reveal">
					<span class="row-num">02</span>
					<div class="row-body">
						<div class="section-head">
							<span class="label">Writing</span>
							<h2 class="section-title">Latest posts</h2>
						</div>

						<div class="posts-list">
							{allPosts.map((post) => (
								<BlogCard post={post} />
							))}
						</div>

						<a href="/blog" class="section-more label">All posts &rarr;</a>
					</div>
				</div>
			)}

		</div>
	</div>

</BaseLayout>

<style>
	/* ── Hero shell — tall so there's scroll room ── */
	.hero {
		position: relative;
		min-height: 200vh;
	}

	/* ── Sticky panel — stays pinned while scrolling through hero ── */
	.hero-sticky {
		position: sticky;
		top: 0;
		height: 100dvh;
		display: flex;
		flex-direction: column;
		overflow: hidden;
		border-bottom: 0.5px solid var(--color-rule);
	}

	/* ── Canvas fills the sticky panel ── */
	.hero-canvas {
		position: absolute;
		inset: 0;
		width: 100%;
		height: 100%;
		display: block;
	}

	/* ── Text content — left-anchored ── */
	.hero-inner {
		position: relative;
		z-index: 1;
		flex: 1;
		display: flex;
		flex-direction: column;
		justify-content: center;
		will-change: opacity, transform;
	}

	.hero-label  { margin-bottom: var(--space-lg); }
	.hero-name   { margin-bottom: var(--space-md); }

	.hero-tagline {
		font-size: var(--text-body);
		color: var(--color-text-secondary);
		line-height: 1.7;
		max-width: 52ch;
		margin-bottom: var(--space-xl);
	}

	.hero-actions {
		display: flex;
		flex-wrap: wrap;
		gap: var(--space-sm);
	}

	/* ── Swiss progress bar ── */
	.hero-progress {
		position: absolute;
		bottom: 0;
		left: 0;
		right: 0;
		height: 1.5px;
		background: var(--color-rule);
		z-index: 2;
	}

	.hero-progress-bar {
		height: 100%;
		width: 0%;
		background: var(--color-rule-heavy);
	}

	/* ── Scroll hint ── */
	.scroll-hint {
		position: absolute;
		bottom: var(--space-xl);
		left: var(--gutter-side);
		z-index: 2;
		display: flex;
		align-items: center;
		gap: var(--space-sm);
		transition: opacity 300ms ease;
	}

	.scroll-line {
		width: 32px;
		height: 0.5px;
		background: var(--color-text-muted);
		position: relative;
		overflow: hidden;
	}

	/* Animated fill on the scroll line */
	.scroll-line::after {
		content: '';
		position: absolute;
		inset: 0;
		background: var(--color-text);
		transform: translateX(-100%);
		animation: scan 1.6s ease-in-out infinite;
	}

	@keyframes scan {
		0%   { transform: translateX(-100%); }
		50%  { transform: translateX(0%); }
		100% { transform: translateX(100%); }
	}

	.scroll-hint .label { color: var(--color-text-muted); }

	/* ── Section chrome ── */
	.section-head { margin-bottom: var(--space-md); }
	.section-head .label { display: block; margin-bottom: 0.3em; }

	.section-title {
		font-size: var(--text-heading);
		font-weight: var(--weight-medium);
		letter-spacing: -0.01em;
	}

	.section-more {
		display: inline-block;
		margin-top: var(--space-md);
		color: var(--color-text-muted);
		transition: color var(--dur-fast) ease;
	}

	.section-more:hover { color: var(--color-text); }

	/* ── Project grid ── */
	.project-grid {
		display: grid;
		grid-template-columns: 1fr 1fr;
		border-top: 0.5px solid var(--color-rule);
		border-left: 0.5px solid var(--color-rule);
	}

	.project-grid > :global(.project-cell) {
		border-right: 0.5px solid var(--color-rule);
		border-bottom: 0.5px solid var(--color-rule);
		transition: background var(--dur-fast) ease;
	}

	.project-grid > :global(.project-cell:hover) {
		background: var(--color-surface);
	}

	/* ── Posts list ── */
	.posts-list { border-top: 0.5px solid var(--color-rule); }

	@media (max-width: 600px) {
		.project-grid { grid-template-columns: 1fr; }
	}

	@media (prefers-reduced-motion: reduce) {
		.scroll-line::after { animation: none; }
	}
</style>

<script>
	/* ── Scroll-driven hero exit ─────────────────────────────────────── */
	function initHeroScroll() {
		const hero        = document.getElementById('hero');
		const heroInner   = document.getElementById('hero-inner');
		const progressBar = document.getElementById('hero-progress-bar');
		const scrollHint  = document.getElementById('scroll-hint');
		if (!hero || !heroInner) return;

		const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

		function easeIn(t: number) { return t * t; }

		function onScroll() {
			const rect       = hero.getBoundingClientRect();
			const scrollable = hero.offsetHeight - window.innerHeight;
			const scrolled   = Math.max(0, -rect.top);
			const progress   = scrollable > 0 ? Math.min(1, scrolled / scrollable) : 0;

			/* Store for canvas to read */
			(window as any).__heroProgress = progress;

			/* Progress bar */
			if (progressBar) progressBar.style.width = `${progress * 100}%`;

			/* Scroll hint fades once you start */
			if (scrollHint) {
				scrollHint.style.opacity = progress < 0.04 ? '1' : '0';
			}

			if (reduced) return;

			/* Text fades + lifts in the second half of the scroll range */
			if (progress > 0.45) {
				const t    = (progress - 0.45) / 0.55;
				const ease = easeIn(Math.min(1, t));
				heroInner.style.opacity   = `${1 - ease}`;
				heroInner.style.transform = `translateY(${-ease * 48}px)`;
			} else {
				heroInner.style.opacity   = '1';
				heroInner.style.transform = 'translateY(0)';
			}
		}

		window.addEventListener('scroll', onScroll, { passive: true });
		onScroll();

		const cleanup = () => {
			window.removeEventListener('scroll', onScroll);
			document.removeEventListener('astro:before-swap', cleanup);
		};
		document.addEventListener('astro:before-swap', cleanup);
	}

	initHeroScroll();
	document.addEventListener('astro:page-load', initHeroScroll);


	/* ── 8-bit canvas ────────────────────────────────────────────────── */
	function initHeroCanvas() {
		const canvas = document.getElementById('hero-canvas') as HTMLCanvasElement | null;
		if (!canvas) return;
		const ctx = canvas.getContext('2d');
		if (!ctx) return;

		if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;

		const CELL      = 18;
		const CHARS     = ['0','1','0','1','0','1','+','·','×','-','0','1'];
		const BASE_FILL = 0.04;
		const MAX_OP    = 0.14;
		const FPS       = 22;
		const INTERVAL  = 1000 / FPS;

		interface Cell {
			x: number; y: number;
			char: string;
			opacity: number;
			target: number;
			speed: number;
			ticksLeft: number;
		}

		let cells: Cell[] = [];
		let raf = 0;
		let last = 0;

		function getCssColor(prop: string) {
			return getComputedStyle(document.documentElement)
				.getPropertyValue(prop).trim();
		}

		function resize() {
			canvas.width  = canvas.offsetWidth;
			canvas.height = canvas.offsetHeight;
			buildCells();
		}

		function buildCells() {
			cells = [];
			const cols = Math.ceil(canvas.width  / CELL) + 1;
			const rows = Math.ceil(canvas.height / CELL) + 1;
			for (let r = 0; r < rows; r++) {
				for (let c = 0; c < cols; c++) {
					cells.push({
						x: c * CELL, y: r * CELL,
						char: CHARS[Math.floor(Math.random() * CHARS.length)],
						opacity: 0,
						target: 0,
						speed: 0.06 + Math.random() * 0.1,
						ticksLeft: Math.floor(Math.random() * FPS * 3),
					});
				}
			}
		}

		function tickCells() {
			/* Density grows as hero scroll progress increases */
			const progress    = (window as any).__heroProgress ?? 0;
			const densityMult = 1 + progress * 5;  /* up to 6× denser at full scroll */
			const fillTarget  = BASE_FILL * densityMult;
			const wantActive  = Math.ceil(cells.length * fillTarget);

			for (const cell of cells) {
				/* Lerp toward target */
				cell.opacity += (cell.target - cell.opacity) * cell.speed;

				if (cell.ticksLeft > 0) { cell.ticksLeft--; continue; }

				/* Settle, schedule next state */
				cell.opacity = cell.target;

				if (cell.target > 0) {
					cell.target    = 0;
					cell.ticksLeft = Math.floor(FPS * (1 + Math.random() * 6));
				} else {
					if (Math.random() < wantActive / cells.length) {
						cell.target    = MAX_OP * (0.25 + Math.random() * 0.75);
						cell.char      = CHARS[Math.floor(Math.random() * CHARS.length)];
						cell.ticksLeft = Math.floor(FPS * (0.4 + Math.random() * 2));
					} else {
						cell.ticksLeft = Math.floor(FPS * (0.2 + Math.random() * 2));
					}
				}
			}
		}

		function draw() {
			ctx.clearRect(0, 0, canvas.width, canvas.height);
			const color = getCssColor('--color-text');
			ctx.font = `${Math.round(CELL * 0.62)}px 'JetBrains Mono', monospace`;
			ctx.textAlign    = 'center';
			ctx.textBaseline = 'middle';

			for (const cell of cells) {
				const op = Math.abs(cell.opacity);
				if (op < 0.005) continue;
				ctx.globalAlpha = op;
				ctx.fillStyle   = color;
				ctx.fillText(cell.char, cell.x + CELL / 2, cell.y + CELL / 2);
			}
			ctx.globalAlpha = 1;
		}

		function loop(ts: number) {
			raf = requestAnimationFrame(loop);
			if (ts - last < INTERVAL) return;
			last = ts;
			tickCells();
			draw();
		}

		const ro = new ResizeObserver(resize);
		ro.observe(canvas);
		resize();
		raf = requestAnimationFrame(loop);

		const cleanup = () => {
			cancelAnimationFrame(raf);
			ro.disconnect();
			document.removeEventListener('astro:before-swap', cleanup);
		};
		document.addEventListener('astro:before-swap', cleanup);
	}

	initHeroCanvas();
	document.addEventListener('astro:page-load', initHeroCanvas);
</script>
