---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import BlogCard from '../components/BlogCard.astro';
import ProjectCard from '../components/ProjectCard.astro';
import { SITE } from '../config/site';

const allPosts = (await getCollection('blog'))
	.filter((p) => !p.data.draft)
	.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
	.slice(0, 4);

const featuredProjects = (await getCollection('projects'))
	.filter((p) => !p.data.draft && p.data.featured)
	.sort((a, b) => a.data.order - b.data.order)
	.slice(0, 4);

/* EDIT: update these focus areas to match your actual expertise */
const focuses = [
	{
		num: '01',
		title: 'Platform Engineering',
		desc: 'Building reliable infrastructure and internal developer platforms — Kubernetes, CI/CD pipelines, and the tooling that lets teams ship with confidence.',
	},
	{
		num: '02',
		title: 'Technical Leadership',
		desc: 'Bridging engineering and product — defining roadmaps, running technical discovery, and moving cross-functional teams from ambiguity to delivery.',
	},
	{
		num: '03',
		title: 'Developer Experience',
		desc: 'Reducing friction in the development loop. Better tooling, observability, and documentation so engineers can focus on problems that matter.',
	},
];
---

<BaseLayout title={SITE.title} description={SITE.description}>

	<!-- ── Hero — 200vh tall, inner panel is sticky ─────────────────── -->
	<section class="hero" id="hero" aria-label="Introduction">
		<canvas id="hero-canvas" class="hero-canvas" aria-hidden="true"></canvas>

		<div class="hero-sticky">
			<!-- Swiss progress bar -->
			<div class="hero-progress" aria-hidden="true">
				<div class="hero-progress-bar" id="hero-progress-bar"></div>
			</div>

			<div class="hero-inner page-wrap" id="hero-inner">
				<p class="label hero-label">Software Engineer</p>
				<h1 class="hero-name">{SITE.author}</h1>
				<p class="hero-tagline">{SITE.description}</p>

				<div class="hero-actions">
					<a href="/resume" class="btn">View Resume</a>
					<a href={SITE.social.github} class="btn" target="_blank" rel="noopener noreferrer">GitHub &nearr;</a>
					<a href={SITE.social.linkedin} class="btn" target="_blank" rel="noopener noreferrer">LinkedIn &nearr;</a>
					<a href={`mailto:${SITE.social.email}`} class="btn">Email</a>
				</div>
			</div>

			<!-- Scroll hint — centred, fades once scrolling begins -->
			<div class="scroll-hint" id="scroll-hint" aria-hidden="true">
				<div class="scroll-line"></div>
				<span class="label">Scroll</span>
			</div>
		</div>
	</section>

	<!-- ── Focus / about section ─────────────────────────────────────── -->
	<section class="focus-section page-wrap" aria-label="Focus areas">

		<div class="focus-intro reveal">
			<p class="label focus-eyebrow">Focus</p>
			<p class="focus-summary">
				Graduate engineer at UBS rotating across infrastructure and platform engineering —
				moving toward technical leadership through systems thinking, developer tooling,
				and building things that last.
			</p>
		</div>

		<div class="focus-grid">
			{focuses.map((f, i) => (
				<div class="focus-item reveal" style={`transition-delay: ${i * 90}ms`}>
					<span class="label focus-num">{f.num}</span>
					<h3 class="focus-title">{f.title}</h3>
					<p class="focus-desc">{f.desc}</p>
				</div>
			))}
		</div>

	</section>

	<!-- ── Projects + Blog ───────────────────────────────────────────── -->
	<div class="page-wrap">
		<div class="doc-rows">

			{featuredProjects.length > 0 && (
				<div class="doc-row reveal">
					<span class="row-num">01</span>
					<div class="row-body">
						<div class="section-head">
							<span class="label">Selected work</span>
							<h2 class="section-title">Projects</h2>
						</div>

						<div class="project-grid">
							{featuredProjects.map((project, i) => (
								<ProjectCard project={project} index={i} />
							))}
						</div>

						<a href="/projects" class="section-more label">All projects &rarr;</a>
					</div>
				</div>
			)}

			{allPosts.length > 0 && (
				<div class="doc-row reveal">
					<span class="row-num">02</span>
					<div class="row-body">
						<div class="section-head">
							<span class="label">Writing</span>
							<h2 class="section-title">Latest posts</h2>
						</div>

						<div class="posts-list">
							{allPosts.map((post) => (
								<BlogCard post={post} />
							))}
						</div>

						<a href="/blog" class="section-more label">All posts &rarr;</a>
					</div>
				</div>
			)}

		</div>
	</div>

</BaseLayout>

<style>
	/* ── Hero shell ── */
	.hero {
		position: relative;
		min-height: 200vh;
	}

	/* ── Sticky panel ── */
	.hero-sticky {
		position: sticky;
		top: 0;
		height: 100dvh;
		display: flex;
		flex-direction: column;
		overflow: hidden;
		border-bottom: 0.5px solid var(--color-rule);
	}

	.hero-canvas {
		position: absolute;
		inset: 0;
		width: 100%;
		height: 100%;
		display: block;
	}

	.hero-inner {
		position: relative;
		z-index: 1;
		flex: 1;
		display: flex;
		flex-direction: column;
		justify-content: center;
		will-change: opacity, transform;
	}

	.hero-label  { margin-bottom: var(--space-lg); }
	.hero-name   { margin-bottom: var(--space-md); }

	.hero-tagline {
		font-size: var(--text-body);
		color: var(--color-text-secondary);
		line-height: 1.7;
		max-width: 52ch;
		margin-bottom: var(--space-xl);
	}

	.hero-actions {
		display: flex;
		flex-wrap: wrap;
		gap: var(--space-sm);
	}

	/* ── Progress bar ── */
	.hero-progress {
		position: absolute;
		bottom: 0;
		left: 0;
		right: 0;
		height: 1.5px;
		background: var(--color-rule);
		z-index: 2;
	}

	.hero-progress-bar {
		height: 100%;
		width: 0%;
		background: var(--color-rule-heavy);
	}

	/* ── Scroll hint — centred at bottom ── */
	.scroll-hint {
		position: absolute;
		bottom: var(--space-xl);
		left: 50%;
		transform: translateX(-50%);
		z-index: 2;
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: var(--space-sm);
		transition: opacity 300ms ease;
		white-space: nowrap;
	}

	.scroll-hint .label { color: var(--color-text-muted); }

	.scroll-line {
		width: 1px;
		height: 32px;
		background: var(--color-rule);
		position: relative;
		overflow: hidden;
	}

	.scroll-line::after {
		content: '';
		position: absolute;
		inset: 0;
		background: var(--color-rule-heavy);
		transform: translateY(-100%);
		animation: scan-down 1.8s ease-in-out infinite;
	}

	@keyframes scan-down {
		0%   { transform: translateY(-100%); }
		50%  { transform: translateY(0%); }
		100% { transform: translateY(100%); }
	}

	/* ── Focus section ── */
	.focus-section {
		padding-top: var(--space-3xl);
		padding-bottom: var(--space-3xl);
		border-bottom: 0.5px solid var(--color-rule);
	}

	.focus-intro {
		display: grid;
		grid-template-columns: auto 1fr;
		gap: var(--space-xl);
		align-items: start;
		margin-bottom: var(--space-2xl);
		padding-bottom: var(--space-xl);
		border-bottom: 0.5px solid var(--color-rule);
	}

	.focus-eyebrow {
		padding-top: 0.2em;
	}

	.focus-summary {
		font-size: 1.0625rem;
		color: var(--color-text-secondary);
		line-height: 1.65;
		max-width: 58ch;
	}

	.focus-grid {
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: 0;
		border-top: 0.5px solid var(--color-rule);
		border-left: 0.5px solid var(--color-rule);
	}

	.focus-item {
		border-right: 0.5px solid var(--color-rule);
		border-bottom: 0.5px solid var(--color-rule);
		padding: var(--space-xl);
	}

	.focus-num {
		display: block;
		margin-bottom: var(--space-lg);
		color: var(--color-text-faint);
	}

	.focus-title {
		font-size: var(--text-heading);
		font-weight: var(--weight-medium);
		color: var(--color-text);
		margin-bottom: var(--space-md);
		letter-spacing: -0.01em;
	}

	.focus-desc {
		font-size: var(--text-body);
		color: var(--color-text-muted);
		line-height: 1.65;
		max-width: none;
	}

	/* ── Section chrome ── */
	.section-head { margin-bottom: var(--space-md); }
	.section-head .label { display: block; margin-bottom: 0.3em; }

	.section-title {
		font-size: var(--text-heading);
		font-weight: var(--weight-medium);
		letter-spacing: -0.01em;
	}

	.section-more {
		display: inline-block;
		margin-top: var(--space-md);
		color: var(--color-text-muted);
		transition: color var(--dur-fast) ease;
	}

	.section-more:hover { color: var(--color-text); }

	/* ── Project grid ── */
	.project-grid {
		display: grid;
		grid-template-columns: 1fr 1fr;
		border-top: 0.5px solid var(--color-rule);
		border-left: 0.5px solid var(--color-rule);
	}

	.project-grid > :global(.project-cell) {
		border-right: 0.5px solid var(--color-rule);
		border-bottom: 0.5px solid var(--color-rule);
		transition: background var(--dur-fast) ease;
	}

	.project-grid > :global(.project-cell:hover) {
		background: var(--color-surface);
	}

	/* ── Posts list ── */
	.posts-list { border-top: 0.5px solid var(--color-rule); }

	@media (max-width: 700px) {
		.focus-grid    { grid-template-columns: 1fr; }
		.focus-intro   { grid-template-columns: 1fr; gap: var(--space-md); }
		.project-grid  { grid-template-columns: 1fr; }
	}

	@media (prefers-reduced-motion: reduce) {
		.scroll-line::after { animation: none; }
	}
</style>

<script>
	/* ── Scroll-driven hero exit ─────────────────────────────────────── */
	function initHeroScroll() {
		const hero        = document.getElementById('hero');
		const heroInner   = document.getElementById('hero-inner');
		const progressBar = document.getElementById('hero-progress-bar');
		const scrollHint  = document.getElementById('scroll-hint');
		if (!hero || !heroInner) return;

		const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

		function easeIn(t: number) { return t * t; }

		function onScroll() {
			const rect       = hero.getBoundingClientRect();
			const scrollable = hero.offsetHeight - window.innerHeight;
			const scrolled   = Math.max(0, -rect.top);
			const progress   = scrollable > 0 ? Math.min(1, scrolled / scrollable) : 0;

			(window as any).__heroProgress = progress;

			if (progressBar) progressBar.style.width = `${progress * 100}%`;
			if (scrollHint)  scrollHint.style.opacity = progress < 0.04 ? '1' : '0';

			if (reduced) return;

			if (progress > 0.45) {
				const t    = (progress - 0.45) / 0.55;
				const ease = easeIn(Math.min(1, t));
				heroInner.style.opacity   = `${1 - ease}`;
				heroInner.style.transform = `translateY(${-ease * 48}px)`;
			} else {
				heroInner.style.opacity   = '1';
				heroInner.style.transform = 'translateY(0)';
			}
		}

		window.addEventListener('scroll', onScroll, { passive: true });
		onScroll();

		const cleanup = () => {
			window.removeEventListener('scroll', onScroll);
			document.removeEventListener('astro:before-swap', cleanup);
		};
		document.addEventListener('astro:before-swap', cleanup);
	}

	initHeroScroll();
	document.addEventListener('astro:page-load', initHeroScroll);


	/* ── 8-bit canvas ────────────────────────────────────────────────── */
	function initHeroCanvas() {
		const canvas = document.getElementById('hero-canvas') as HTMLCanvasElement | null;
		if (!canvas) return;
		const ctx = canvas.getContext('2d');
		if (!ctx) return;
		if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;

		const CELL      = 18;
		const CHARS     = ['0','1','0','1','0','1','+','·','×','-','0','1'];
		const BASE_FILL = 0.04;
		const FPS       = 22;
		const INTERVAL  = 1000 / FPS;

		/* Light mode needs much higher opacity — dark chars on pale bg need
		   ~3× more alpha to register at the same perceived brightness        */
		function getMaxOpacity(): number {
			const theme      = document.documentElement.dataset.theme;
			const prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
			const isDark     = theme === 'dark' || (!theme && prefersDark);
			return isDark ? 0.20 : 0.55;
		}

		interface Cell {
			x: number; y: number;
			char: string;
			opacity: number;
			target: number;
			speed: number;
			ticksLeft: number;
		}

		let cells: Cell[] = [];
		let raf = 0;
		let last = 0;

		function getCssColor(prop: string) {
			return getComputedStyle(document.documentElement)
				.getPropertyValue(prop).trim();
		}

		function resize() {
			canvas.width  = canvas.offsetWidth;
			canvas.height = canvas.offsetHeight;
			buildCells();
		}

		function buildCells() {
			cells = [];
			const cols = Math.ceil(canvas.width  / CELL) + 1;
			const rows = Math.ceil(canvas.height / CELL) + 1;
			for (let r = 0; r < rows; r++) {
				for (let c = 0; c < cols; c++) {
					cells.push({
						x: c * CELL, y: r * CELL,
						char: CHARS[Math.floor(Math.random() * CHARS.length)],
						opacity: 0,
						target: 0,
						speed: 0.06 + Math.random() * 0.1,
						ticksLeft: Math.floor(Math.random() * FPS * 3),
					});
				}
			}
		}

		function tickCells() {
			const progress    = (window as any).__heroProgress ?? 0;
			const densityMult = 1 + progress * 5;
			const fillTarget  = BASE_FILL * densityMult;
			const wantActive  = Math.ceil(cells.length * fillTarget);
			const maxOp       = getMaxOpacity();

			for (const cell of cells) {
				cell.opacity += (cell.target - cell.opacity) * cell.speed;

				if (cell.ticksLeft > 0) { cell.ticksLeft--; continue; }

				cell.opacity = cell.target;

				if (cell.target > 0) {
					cell.target    = 0;
					cell.ticksLeft = Math.floor(FPS * (1 + Math.random() * 6));
				} else {
					if (Math.random() < wantActive / cells.length) {
						cell.target    = maxOp * (0.25 + Math.random() * 0.75);
						cell.char      = CHARS[Math.floor(Math.random() * CHARS.length)];
						cell.ticksLeft = Math.floor(FPS * (0.4 + Math.random() * 2));
					} else {
						cell.ticksLeft = Math.floor(FPS * (0.2 + Math.random() * 2));
					}
				}
			}
		}

		function draw() {
			ctx.clearRect(0, 0, canvas.width, canvas.height);
			const color = getCssColor('--color-text');
			ctx.font = `${Math.round(CELL * 0.62)}px 'JetBrains Mono', monospace`;
			ctx.textAlign    = 'center';
			ctx.textBaseline = 'middle';

			for (const cell of cells) {
				const op = Math.abs(cell.opacity);
				if (op < 0.005) continue;
				ctx.globalAlpha = op;
				ctx.fillStyle   = color;
				ctx.fillText(cell.char, cell.x + CELL / 2, cell.y + CELL / 2);
			}
			ctx.globalAlpha = 1;
		}

		function loop(ts: number) {
			raf = requestAnimationFrame(loop);
			if (ts - last < INTERVAL) return;
			last = ts;
			tickCells();
			draw();
		}

		const ro = new ResizeObserver(resize);
		ro.observe(canvas);
		resize();
		raf = requestAnimationFrame(loop);

		const cleanup = () => {
			cancelAnimationFrame(raf);
			ro.disconnect();
			document.removeEventListener('astro:before-swap', cleanup);
		};
		document.addEventListener('astro:before-swap', cleanup);
	}

	initHeroCanvas();
	document.addEventListener('astro:page-load', initHeroCanvas);
</script>
