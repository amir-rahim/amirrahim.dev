---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import BlogCard from '../components/BlogCard.astro';
import ProjectCard from '../components/ProjectCard.astro';
import { SITE } from '../config/site';

const allPosts = (await getCollection('blog'))
	.filter((p) => !p.data.draft)
	.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
	.slice(0, 4);

const featuredProjects = (await getCollection('projects'))
	.filter((p) => !p.data.draft && p.data.featured)
	.sort((a, b) => a.data.order - b.data.order)
	.slice(0, 4);
---

<BaseLayout title={SITE.title} description={SITE.description}>

	<!-- Full-bleed hero (outside page-wrap so it spans the viewport) -->
	<section class="hero" aria-label="Introduction">
		<canvas id="hero-canvas" class="hero-canvas" aria-hidden="true"></canvas>

		<div class="hero-inner page-wrap">
			<p class="label hero-label">Software Engineer</p>
			<h1 class="hero-name">{SITE.author}</h1>
			<p class="hero-tagline">{SITE.description}</p>

			<div class="hero-actions">
				<a href="/resume" class="btn">View Resume</a>
				<a
					href={SITE.social.github}
					class="btn"
					target="_blank"
					rel="noopener noreferrer"
				>GitHub &nearr;</a>
				<a
					href={SITE.social.linkedin}
					class="btn"
					target="_blank"
					rel="noopener noreferrer"
				>LinkedIn &nearr;</a>
				<a href={`mailto:${SITE.social.email}`} class="btn">Email</a>
			</div>
		</div>
	</section>

	<!-- Numbered content sections -->
	<div class="page-wrap">
		<div class="doc-rows">

			<!-- 01 - Projects -->
			{featuredProjects.length > 0 && (
				<div class="doc-row reveal">
					<span class="row-num">01</span>
					<div class="row-body">
						<div class="section-head">
							<span class="label">Selected work</span>
							<h2 class="section-title">Projects</h2>
						</div>

						<div class="project-grid">
							{featuredProjects.map((project, i) => (
								<ProjectCard project={project} index={i} />
							))}
						</div>

						<a href="/projects" class="section-more label">All projects &rarr;</a>
					</div>
				</div>
			)}

			<!-- 02 - Writing -->
			{allPosts.length > 0 && (
				<div class="doc-row reveal">
					<span class="row-num">02</span>
					<div class="row-body">
						<div class="section-head">
							<span class="label">Writing</span>
							<h2 class="section-title">Latest posts</h2>
						</div>

						<div class="posts-list">
							{allPosts.map((post) => (
								<BlogCard post={post} />
							))}
						</div>

						<a href="/blog" class="section-more label">All posts &rarr;</a>
					</div>
				</div>
			)}

		</div>
	</div>

</BaseLayout>

<style>
	/* Full-viewport hero */
	.hero {
		position: relative;
		overflow: hidden;
		min-height: calc(100dvh - 2.875rem); /* subtract sticky nav */
		display: flex;
		align-items: center;
		border-bottom: 0.5px solid var(--color-rule);
	}

	/* Canvas fills hero entirely */
	.hero-canvas {
		position: absolute;
		inset: 0;
		width: 100%;
		height: 100%;
		display: block;
	}

	/* Content sits above canvas */
	.hero-inner {
		position: relative;
		z-index: 1;
		padding-top: var(--space-3xl);
		padding-bottom: var(--space-3xl);
		max-width: 640px; /* constrain text width regardless of page-wrap */
	}

	.hero-label  { margin-bottom: var(--space-lg); }
	.hero-name   { margin-bottom: var(--space-md); }

	.hero-tagline {
		font-size: var(--text-body);
		color: var(--color-text-secondary);
		line-height: 1.7;
		max-width: 42ch;
		margin-bottom: var(--space-xl);
	}

	.hero-actions {
		display: flex;
		flex-wrap: wrap;
		gap: var(--space-sm);
	}

	/* Section chrome */
	.section-head { margin-bottom: var(--space-md); }

	.section-head .label {
		display: block;
		margin-bottom: 0.3em;
	}

	.section-title {
		font-size: var(--text-heading);
		font-weight: var(--weight-medium);
		letter-spacing: -0.01em;
	}

	.section-more {
		display: inline-block;
		margin-top: var(--space-md);
		color: var(--color-text-muted);
		transition: color var(--dur-fast) ease;
	}

	.section-more:hover { color: var(--color-text); }

	/* Project grid — border-collapse technique */
	.project-grid {
		display: grid;
		grid-template-columns: 1fr 1fr;
		border-top: 0.5px solid var(--color-rule);
		border-left: 0.5px solid var(--color-rule);
	}

	.project-grid > :global(.project-cell) {
		border-right: 0.5px solid var(--color-rule);
		border-bottom: 0.5px solid var(--color-rule);
		transition: background var(--dur-fast) ease;
	}

	.project-grid > :global(.project-cell:hover) {
		background: var(--color-surface);
	}

	/* Posts list */
	.posts-list { border-top: 0.5px solid var(--color-rule); }

	@media (max-width: 600px) {
		.project-grid { grid-template-columns: 1fr; }
		.hero-inner { padding-top: var(--space-2xl); padding-bottom: var(--space-2xl); }
	}
</style>

<script>
	/* 8-bit character grid animation */
	function initHeroCanvas() {
		const canvas = document.getElementById('hero-canvas') as HTMLCanvasElement | null;
		if (!canvas) return;

		const ctx = canvas.getContext('2d');
		if (!ctx) return;

		if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;

		const CELL   = 18;          /* px per grid cell — chunky 8-bit feel  */
		const CHARS  = ['0', '1', '0', '1', '0', '1', '+', '·', '×', '-'];
		const MAX_OP = 0.13;        /* highest a cell can glow                */

		interface Cell {
			x: number; y: number;
			char: string;
			opacity: number;
			target: number;
			decay: number;
			ticksLeft: number;
		}

		let cells: Cell[] = [];
		let raf = 0;
		let lastTime = 0;
		const FPS = 20;
		const INTERVAL = 1000 / FPS;

		function getCssColor(prop: string): string {
			return getComputedStyle(document.documentElement)
				.getPropertyValue(prop).trim();
		}

		function resize() {
			canvas.width  = canvas.offsetWidth;
			canvas.height = canvas.offsetHeight;
			buildCells();
		}

		function buildCells() {
			cells = [];
			const cols = Math.ceil(canvas.width  / CELL) + 1;
			const rows = Math.ceil(canvas.height / CELL) + 1;
			for (let r = 0; r < rows; r++) {
				for (let c = 0; c < cols; c++) {
					cells.push({
						x: c * CELL,
						y: r * CELL,
						char: CHARS[Math.floor(Math.random() * CHARS.length)],
						opacity: 0,
						target: 0,
						decay: 0.008 + Math.random() * 0.018,
						ticksLeft: Math.floor(Math.random() * FPS * 4),
					});
				}
			}
		}

		function tickCells() {
			const active = Math.ceil(cells.length * 0.04); /* ~4% lit at once */
			for (const cell of cells) {
				if (cell.ticksLeft > 0) {
					cell.ticksLeft--;
					/* lerp toward target */
					cell.opacity += (cell.target - cell.opacity) * cell.decay;
					continue;
				}
				/* settle and schedule next state */
				cell.opacity = cell.target;
				if (cell.target > 0) {
					/* turn off, rest for a while */
					cell.target = 0;
					cell.ticksLeft = Math.floor(FPS * (2 + Math.random() * 8));
				} else {
					/* maybe turn on */
					if (Math.random() < active / cells.length) {
						cell.target   = MAX_OP * (0.3 + Math.random() * 0.7);
						cell.char     = CHARS[Math.floor(Math.random() * CHARS.length)];
						cell.ticksLeft = Math.floor(FPS * (0.5 + Math.random() * 2));
					} else {
						cell.ticksLeft = Math.floor(FPS * (0.5 + Math.random() * 3));
					}
				}
			}
		}

		function draw() {
			ctx.clearRect(0, 0, canvas.width, canvas.height);
			const color = getCssColor('--color-text');
			ctx.font = `${Math.round(CELL * 0.65)}px 'JetBrains Mono', monospace`;
			ctx.textAlign    = 'center';
			ctx.textBaseline = 'middle';

			for (const cell of cells) {
				const op = Math.abs(cell.opacity);
				if (op < 0.005) continue;
				ctx.globalAlpha = op;
				ctx.fillStyle   = color;
				ctx.fillText(cell.char, cell.x + CELL / 2, cell.y + CELL / 2);
			}
			ctx.globalAlpha = 1;
		}

		function loop(ts: number) {
			raf = requestAnimationFrame(loop);
			if (ts - lastTime < INTERVAL) return;
			lastTime = ts;
			tickCells();
			draw();
		}

		const ro = new ResizeObserver(resize);
		ro.observe(canvas);
		resize();
		raf = requestAnimationFrame(loop);

		/* Clean up when View Transitions swap the DOM */
		const cleanup = () => {
			cancelAnimationFrame(raf);
			ro.disconnect();
			document.removeEventListener('astro:before-swap', cleanup);
		};
		document.addEventListener('astro:before-swap', cleanup);
	}

	initHeroCanvas();
	document.addEventListener('astro:page-load', initHeroCanvas);
</script>
