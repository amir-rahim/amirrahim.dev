---
import type { CollectionEntry } from 'astro:content';
import BaseLayout from './BaseLayout.astro';
import FormattedDate from '../components/FormattedDate.astro';

type Props = CollectionEntry<'blog'>['data'] & { ogImage?: string };

const { title, description, pubDate, updatedDate, tags, ogImage } = Astro.props;
---

<BaseLayout title={title} description={description} ogImage={ogImage}>
	<div class="page-wrap">

		<!-- Post header -->
		<header class="post-header reveal">
			<div class="post-meta-row">
				<time class="label" datetime={pubDate.toISOString()}>
					<FormattedDate date={pubDate} />
				</time>
				{updatedDate && (
					<span class="label post-updated">
						Updated <FormattedDate date={updatedDate} />
					</span>
				)}
				{tags.length > 0 && (
					<span class="label post-tags">{tags.join(' · ')}</span>
				)}
			</div>

			<h1 class="post-title">{title}</h1>
			{description && <p class="post-desc">{description}</p>}
		</header>

		<!-- Post body in numbered doc-row -->
		<div class="doc-rows">
			<div class="doc-row">
				<span class="row-num" aria-hidden="true">↓</span>
				<div class="row-body">
					<div class="prose post-body">
						<slot />
					</div>
				</div>
			</div>
		</div>

		<!-- Footer nav -->
		<div class="post-footer">
			<a href="/blog" class="label back-link">← All posts</a>
		</div>

	</div>
</BaseLayout>

<style>
	.post-header {
		padding-top: var(--space-2xl);
		padding-bottom: var(--space-xl);
		border-bottom: 0.5px solid var(--color-rule);
	}

	.post-meta-row {
		display: flex;
		flex-wrap: wrap;
		align-items: center;
		gap: var(--space-lg);
		margin-bottom: var(--space-md);
	}

	.post-meta-row .label { color: var(--color-text-muted); }

	.post-updated { color: var(--color-text-faint); }
	.post-tags    { color: var(--color-text-faint); }

	.post-title {
		font-size: clamp(1.6rem, 3.5vw, 2.4rem);
		letter-spacing: -0.025em;
		margin-bottom: var(--space-sm);
	}

	.post-desc {
		font-size: var(--text-body);
		color: var(--color-text-muted);
		line-height: 1.65;
		margin-top: var(--space-sm);
	}

	.post-body { padding-block: var(--space-sm); }

	.post-footer {
		padding-block: var(--space-xl);
		border-top: 0.5px solid var(--color-rule);
	}

	.back-link {
		color: var(--color-text-muted);
		transition: color var(--dur-fast) ease;
	}

	.back-link:hover { color: var(--color-text); }
</style>
